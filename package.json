{
  "name": "paynpik",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\" \"npm run dev:customer\"",
    "dev:api": "npm run dev --workspace=apps/api",
    "dev:web": "npm run dev --workspace=apps/web",
    "dev:customer": "npm run dev --workspace=apps/customer",
    "build": "npm run build --workspaces",
    "build:api": "bash scripts/build-api.sh",
    "build:web": "bash scripts/build-web.sh",
    "build:customer": "bash scripts/build-customer.sh",
    "build:all": "npm run build:api && npm run build:web && npm run build:customer",
    "lint": "npm run lint --workspaces",
    "docker:dev": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "db:migrate": "npm run db:migrate --workspace=apps/api",
    "db:seed": "npm run db:seed --workspace=apps/api",
    "db:studio": "npm run db:studio --workspace=apps/api"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
