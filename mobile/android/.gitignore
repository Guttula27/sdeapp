# Capacitor + Android build artifacts. The android/ folder is
# regenerated by `npx cap add android` whenever someone clones the
# repo and wants to build, so we don't track it. Same for build
# outputs.

node_modules/

# Native Android project — auto-generated, do not commit.
# To rebuild from scratch: `npx cap add android && npx cap sync android`
android/

# Resources for icon/splash generation. Replace with real 1024x1024
# and 2732x2732 PNGs to brand the APK; the files themselves are
# build-time artifacts we don't track.
resources/icon.png
resources/splash.png
resources/icon-foreground.png
resources/icon-background.png

# Secrets — keystore + signing config never go in git
*.keystore
*.jks
keystore.properties

# IDE files
.idea/
.vscode/
*.iml
