generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum BusinessType {
  RESTAURANT
  QSR
  FOOD_COURT
  CAFETERIA
  PARCEL_OUTLET
  DINE_IN
  HYBRID
}

enum OutletType {
  SELF_SERVICE
  SELF_SERVICE_PARCEL
  DINE_IN_PREPAID
  DINE_IN_POSTPAID
  HYBRID
}

enum OrderStatus {
  CREATED
  QUEUED
  PREPARING
  READY
  // Parcel-path service step: kitchen finished, parcel station is packaging
  // / staging it. Customer gets a "ready for pickup" alert on entry. Maps
  // to the same point in the lifecycle as OUT_FOR_SERVICE for table service.
  READY_FOR_PICKUP
  OUT_FOR_SERVICE
  SERVED
  CANCELLED
  DISPUTED
  RESOLVED
  FOR_REFUND
  REFUND_COMPLETE
}

enum OrderItemStatus {
  PENDING
  PREPARING
  READY
  SERVED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum PaymentMode {
  UPI
  CARD
  CASH
  WALLET
  NET_BANKING
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  EXPIRED
  SUSPENDED
}

enum QRType {
  TABLE
  OUTLET
  CUSTOMER
  PAYMENT
}

// ─── 3rd-party integrations & messaging ──────────────────
enum IntegrationChannel {
  WHATSAPP
  SMS
  EMAIL
  PAYMENT_GATEWAY
}

enum TemplateChannel {
  WHATSAPP
  SMS
  EMAIL
}

enum TemplateScope {
  PLATFORM
  BUSINESS
  OUTLET
}

enum TemplateCategory {
  TRANSACTIONAL
  PROMOTIONAL
  UTILITY
  AUTH
}

// Approval workflow:
//   DRAFT             → editable by author
//   PENDING_PLATFORM  → submitted by business/outlet, awaiting platform admin review
//   PENDING_PROVIDER  → platform approved, awaiting provider (Meta/Gupshup/etc.) review
//   APPROVED          → live, usable for sending
//   REJECTED          → rejected by platform or provider, see rejectionReason
enum TemplateApprovalStatus {
  DRAFT
  PENDING_PLATFORM
  PENDING_PROVIDER
  APPROVED
  REJECTED
}

// ─── Platform / Auth ─────────────────────────────────────

model User {
  id           String     @id @default(cuid())
  email        String?    @unique
  phone        String     @unique
  name         String
  passwordHash String?
  status       UserStatus @default(ACTIVE)
  avatarUrl    String?

  roleId     String?
  role       Role?     @relation(fields: [roleId], references: [id])
  businessId String?
  business   Business? @relation(fields: [businessId], references: [id])
  outletId   String?
  outlet     Outlet?   @relation(fields: [outletId], references: [id])

  customerOrders         Order[]                 @relation("CustomerOrders")
  staffOrders            Order[]                 @relation("StaffOrders")
  customerClusterOrders  ClusterOrder[]          @relation("CustomerClusterOrders")
  customerAlerts         CustomerAlert[]
  sessions               Session[]
  auditLogs              AuditLog[]
  kitchenStations        KitchenStation[]        @relation("StationWorker")
  serviceStationWorkers  ServiceStationWorker[]
  customerTagAssignments CustomerTagAssignment[] @relation("UserCustomerTagAssignments")
  favorites              Favorite[]
  outletLinks            OutletCustomer[]        @relation("UserOutletLinks")
  responsibilities       UserResponsibility[]
  orderItemReviews       OrderItemReview[]       @relation("ReviewByCustomer")
  reviewReplies          OrderItemReview[]       @relation("ReviewReplyBy")
  couponTargets          CouponCustomer[]        @relation("CouponTargets")
  couponUsages           CouponUsage[]           @relation("CouponUsages")
  rewardAccount          CustomerRewardAccount?  @relation("RewardAccount")
  rewardTransactions     RewardTransaction[]     @relation("RewardTransactions")
  preferredUpiApp        String?
  profileImageUrl        String?                 @db.Text
  alertRingtone          String?                 @default("chime")
  alertVolume            Int?                    @default(70)
  mustChangePassword     Boolean                 @default(false)
  preferredLanguage      String?                 @default("en")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("paynpik_users")
}

model Role {
  id          String    @id @default(cuid())
  name        String
  description String?
  isSystem    Boolean   @default(false)
  // Template roles live at platform scope (businessId null) and act as
  // defaults that get cloned into each new business's role of the same name.
  // Edits to a template cascade to every per-business copy.
  isTemplate  Boolean   @default(false)
  businessId  String?
  business    Business? @relation(fields: [businessId], references: [id])
  outletId    String?
  outlet      Outlet?   @relation(fields: [outletId], references: [id])

  responsibilities RoleResponsibility[]
  users            User[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([businessId])
  @@index([outletId])
  @@map("paynpik_roles")
}

model Responsibility {
  id          String  @id @default(cuid())
  name        String  @unique
  description String?
  module      String

  roles RoleResponsibility[]
  users UserResponsibility[]

  @@map("paynpik_responsibilities")
}

model UserResponsibility {
  userId           String
  responsibilityId String
  // true  → grant this permission on top of the user's role
  // false → revoke this permission from the user's role
  granted          Boolean

  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  responsibility Responsibility @relation(fields: [responsibilityId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@id([userId, responsibilityId])
  @@map("paynpik_user_responsibilities")
}

// ─── Internationalisation ─────────────────────────────────
model Language {
  code       String  @id // ISO 639-1, e.g. "en", "hi", "ta"
  name       String // English display name, e.g. "Hindi"
  nativeName String // Native display name, e.g. "हिन्दी"
  isEnabled  Boolean @default(true)

  translations Translation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("paynpik_languages")
}

model Translation {
  entityType   String // e.g. "Item", "Category", "Outlet", "Order.itemSnapshot"
  entityId     String
  fieldName    String // e.g. "name", "description", "address"
  languageCode String
  value        String @db.Text
  source       String @default("auto") // "auto" | "manual"

  language Language @relation(fields: [languageCode], references: [code], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@id([entityType, entityId, fieldName, languageCode])
  @@index([entityType, languageCode])
  @@map("paynpik_translations")
}

model RoleResponsibility {
  roleId           String
  responsibilityId String
  role             Role           @relation(fields: [roleId], references: [id], onDelete: Cascade)
  responsibility   Responsibility @relation(fields: [responsibilityId], references: [id], onDelete: Cascade)

  @@id([roleId, responsibilityId])
  @@map("paynpik_role_responsibilities")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // JWTs comfortably exceed VARCHAR(191). Bump to 500 so MySQL can still
  // index the column (TEXT can't hold a unique index without a prefix).
  token     String   @unique @db.VarChar(500)
  ipAddress String?
  userAgent String?
  expiresAt DateTime

  createdAt DateTime @default(now())

  @@map("paynpik_sessions")
}

model AuditLog {
  id        String  @id @default(cuid())
  userId    String?
  user      User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String
  module    String
  entityId  String?
  oldValue  Json?
  newValue  Json?
  ipAddress String?

  createdAt DateTime @default(now())

  @@map("paynpik_audit_logs")
}

// ─── Business Hierarchy ──────────────────────────────────

model Facility {
  id               String   @id @default(cuid())
  name             String
  address          String
  facilityType     String
  totalSeating     Int?
  operationalHours Json?
  businessId       String
  business         Business @relation(fields: [businessId], references: [id])

  outlets Outlet[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("paynpik_facilities")
}

model Business {
  id              String       @id @default(cuid())
  name            String
  description     String?      @db.VarChar(250)
  address         String?
  addressLine1    String?
  addressLine2    String?
  city            String?
  state           String?
  pincode         String?
  country         String?      @default("India")
  mapsLocation    String?
  gstNumber       String?
  upiId           String?
  businessType    BusinessType
  logoUrl         String?      @db.Text
  thumbnailUrl    String?      @db.Text
  primaryImageUrl String?      @db.Text
  status          UserStatus   @default(ACTIVE)

  // Short, public-shareable identifier (e.g. "BIZ-A4F23C81"). Required for
  // Cluster businesses since they need a QR-resolvable code; backfilled for
  // every business at migration time so the column is uniformly populated.
  publicCode String? @unique @db.VarChar(20)

  // CLUSTER: a Business of category "Cluster" is a logical roof (food court,
  // theatre) that aggregates outlets from other businesses. It owns no outlets
  // of its own — its `outlets` collection stays empty — and instead pulls
  // member outlets in via the ClusterMember join. Customers see all members
  // under one shell with a unified cart and a single payment that the backend
  // splits per outlet (Razorpay Route).
  isCluster Boolean @default(false)

  // When true the business uses multiple menus (e.g. Breakfast / Lunch / Dinner).
  // When false a single hidden "Main Menu" is used and the UI hides menu tabs.
  // Every business has at least one Menu row regardless of the flag.
  multipleMenusEnabled Boolean @default(false)

  subscriptionId String?       @unique
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id])

  outlets    Outlet[]
  users      User[]
  roles      Role[]
  facilities Facility[]
  vendors    Vendor[]
  materials  Material[]
  images     BusinessImage[]
  categories Category[]
  menus      Menu[]

  // Cluster relations — only populated when isCluster = true.
  clusterMembers ClusterMember[] @relation("ClusterMembership")
  clusterOrders  ClusterOrder[]  @relation("ClusterOrders")

  messageTemplates MessageTemplate[]

  // Promotions (coupons / discounts / bundles / offers) authored at the
  // business level. Outlet-scope rows live in the corresponding tables too,
  // selected by outletId.
  coupons   Coupon[]
  discounts Discount[]
  offers    Offer[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("paynpik_businesses")
}

model BusinessImage {
  id           String   @id @default(cuid())
  businessId   String
  business     Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  url          String   @db.Text
  displayOrder Int      @default(0)

  createdAt DateTime @default(now())

  @@index([businessId, displayOrder])
  @@map("paynpik_business_images")
}

model Outlet {
  id              String     @id @default(cuid())
  // Short, cryptic, human-shareable identifier (e.g. "OL-A4F23C81"). Used
  // wherever the long CUID would be unwieldy: invoices, support tickets,
  // staff/customer reference. Generated at create time; one per outlet for
  // life. The migration backfills existing rows deterministically from id.
  publicCode      String?    @unique @db.VarChar(20)
  name            String
  outletType      OutletType
  address         String?
  addressLine1    String?
  addressLine2    String?
  city            String?
  state           String?
  pincode         String?
  country         String?    @default("India")
  mapsLocation    String?
  description     String?    @db.VarChar(250)
  phone           String?
  gstNumber       String?
  upiId           String?
  logoUrl         String?    @db.Text
  primaryImageUrl String?    @db.Text
  isActive        Boolean    @default(true)

  // Outlet-level operations defaults. Parcel is available everywhere by
  // default — the obsolete SELF_SERVICE_PARCEL outlet type has been retired
  // and counter / hybrid outlets all offer parcel out of the box.
  defaultPrepTime     Int?
  parcelChargeEnabled Boolean @default(true)
  defaultParcelCharge Decimal @default(0) @db.Decimal(10, 2)

  // Persistent order sequence (continuous across days). orderNumber on each
  // created order pulls + increments this counter atomically. Token counter is
  // configurable: tokenStartNumber is the value reset() returns to, and
  // nextTokenNumber is the next token to be issued.
  nextOrderSequence Int @default(1)
  tokenStartNumber  Int @default(1)
  nextTokenNumber   Int @default(1)

  // Per-outlet master switch for the multi-menu UI. The business flag
  // (Business.multipleMenusEnabled) controls whether menus can be authored;
  // this flag controls whether customers, staff and outlet admins at this
  // outlet see them. When false, only the default menu's categories are
  // returned by /outlets/:id/menu, regardless of other menus' enable state.
  multipleMenusEnabled Boolean @default(false)

  // GST / tax config
  gstApplicable    Boolean @default(false)
  gstPercent       Decimal @default(0) @db.Decimal(5, 2)
  priceIncludesGst Boolean @default(false)

  // Razorpay Route — the outlet's Razorpay Linked Account (LA) ID. When the
  // outlet is a member of a Cluster, the cluster's payment is split via
  // Razorpay's `transfers` array so funds settle directly to this LA.
  // In stubbed test mode (RAZORPAY_STUB_TRANSFERS=true) the split is computed
  // and persisted on ClusterOrder.routeTransfers, but no real transfer fires.
  razorpayLinkedAccountId String?
  businessId              String
  business                Business  @relation(fields: [businessId], references: [id])
  facilityId              String?
  facility                Facility? @relation(fields: [facilityId], references: [id])

  users                  User[]
  sections               Section[]
  categories             Category[]
  orders                 Order[]
  tables                 Table[]
  qrCodes                QRCode[]
  kitchenStations        KitchenStation[]
  serviceStations        ServiceStation[]
  customerTags           CustomerTag[]
  customerTagAssignments CustomerTagAssignment[] @relation("OutletCustomerTagAssignments")
  toppings               Topping[]
  images                 OutletImage[]
  hours                  OutletHour[]
  tableTypes             TableType[]
  customerLinks          OutletCustomer[]        @relation("OutletCustomerLinks")
  roles                  Role[]
  menus                  OutletMenu[]
  messageTemplates       MessageTemplate[]

  // 1:1 with ClusterMember (the join row makes outletId unique, so an
  // outlet is in at most one cluster at a time — "cluster-exclusive while
  // linked" semantics).
  clusterMembership ClusterMember? @relation("OutletClusterMembership")

  // Whether this outlet accepts reward-point redemptions at checkout. The
  // earn side is always on (customers earn points everywhere they spend);
  // burn side is a per-outlet business decision.
  acceptRewardRedemption Boolean @default(true)

  // Kitchen-station receipt printing. When `kitchenAutoPrint` is on, each
  // station auto-prints its slice of every confirmed order to the printer
  // assigned to it. When `kitchenAllowManualPrint` is on, station staff can
  // tap a Print button on a ticket to print on demand. Both default off so
  // outlets opt-in explicitly.
  kitchenAutoPrint        Boolean @default(false)
  kitchenAllowManualPrint Boolean @default(false)

  // Per-outlet promotion rows. Business-wide promotions live with
  // outletId = null and apply to every outlet under the business.
  coupons   Coupon[]
  discounts Discount[]
  offers    Offer[]
  printers  Printer[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("paynpik_outlets")
}

model Section {
  id       String  @id @default(cuid())
  name     String
  isActive Boolean @default(true)
  outletId String
  outlet   Outlet  @relation(fields: [outletId], references: [id])

  tables Table[]
  orders Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("paynpik_sections")
}

model Table {
  id          String     @id @default(cuid())
  number      String
  capacity    Int        @default(4)
  isActive    Boolean    @default(true)
  sectionId   String?
  section     Section?   @relation(fields: [sectionId], references: [id])
  outletId    String
  outlet      Outlet     @relation(fields: [outletId], references: [id])
  tableTypeId String?
  tableType   TableType? @relation(fields: [tableTypeId], references: [id])

  qrCode              QRCode?
  orders              Order[]
  serviceStationLinks ServiceStationTable[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("paynpik_tables")
}

model QRCode {
  id       String  @id @default(cuid())
  type     QRType
  code     String  @unique
  // Base64 PNG data URL — easily 5-20KB, so it has to be Text on MySQL.
  imageUrl String? @db.Text
  isActive Boolean @default(true)

  outletId String?
  outlet   Outlet? @relation(fields: [outletId], references: [id])
  tableId  String? @unique
  table    Table?  @relation(fields: [tableId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("paynpik_qr_codes")
}

// ─── Menu ─────────────────────────────────────────────────

model Category {
  id           String  @id @default(cuid())
  name         String
  imageUrl     String? @db.Text
  displayOrder Int     @default(0)
  isActive     Boolean @default(true)

  // A category belongs to either an outlet (the outlet's live menu) or a
  // business (a template menu outlets can import). Exactly one of outletId /
  // businessId must be set — enforced in service layer.
  outletId   String?
  outlet     Outlet?   @relation(fields: [outletId], references: [id])
  businessId String?
  business   Business? @relation(fields: [businessId], references: [id])

  // Parent menu. Nullable for legacy categories; the data migration backfills
  // every existing category to its business's default "Main Menu". New
  // categories should always set this. When the business's
  // multipleMenusEnabled flag is OFF the UI hides the menu picker and assigns
  // the default menu transparently.
  menuId String?
  menu   Menu?   @relation(fields: [menuId], references: [id])

  subcategories Subcategory[]
  discounts     Discount[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([outletId])
  @@index([businessId])
  @@index([menuId])
  @@map("paynpik_categories")
}

model Subcategory {
  id           String   @id @default(cuid())
  name         String
  imageUrl     String?  @db.Text
  displayOrder Int      @default(0)
  isActive     Boolean  @default(true)
  categoryId   String
  category     Category @relation(fields: [categoryId], references: [id])

  items     Item[]
  discounts Discount[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("paynpik_subcategories")
}

// ─── Menus ─────────────────────────────────────────────────────
// A Menu groups a set of Categories under a Business (e.g. Breakfast, Lunch).
// Every business has at least one "Main Menu" (auto-seeded). When the
// business's multipleMenusEnabled flag is OFF, the UI hides tabs and treats
// the single menu as implicit. Outlets opt in to specific menus via OutletMenu.

model Menu {
  id           String   @id @default(cuid())
  businessId   String
  business     Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name         String
  description  String?  @db.VarChar(250)
  isActive     Boolean  @default(true)
  displayOrder Int      @default(0)
  // Marks the auto-seeded default menu so we can prevent deletion. There's
  // always exactly one isDefault=true per business.
  isDefault    Boolean  @default(false)

  timingSlots    MenuTimingSlot[]
  categories     Category[]
  outletLinks    OutletMenu[]
  orderItems     OrderItem[]
  tableTypeLinks TableTypeMenu[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([businessId, displayOrder])
  @@map("paynpik_menus")
}

// Per-day-of-week availability slot. Multiple slots per day are allowed to
// model split shifts (e.g. Tue 07:00-10:00 + 18:00-22:00). dayOfWeek follows
// ISO: 1=Mon .. 7=Sun. Times are stored as minutes-since-midnight (0..1440)
// so the API can do clean comparisons without timezone parsing.
model MenuTimingSlot {
  id          String @id @default(cuid())
  menuId      String
  menu        Menu   @relation(fields: [menuId], references: [id], onDelete: Cascade)
  dayOfWeek   Int
  startMinute Int
  endMinute   Int

  @@index([menuId, dayOfWeek])
  @@map("paynpik_menu_timing_slots")
}

// Join row: this outlet imports/exposes this menu. Carries the outlet's
// enable toggle and optional timing override (when overrideTimings=true, the
// slots in OutletMenuTimingSlot take precedence; otherwise the business
// Menu.timingSlots apply).
model OutletMenu {
  id              String  @id @default(cuid())
  outletId        String
  outlet          Outlet  @relation(fields: [outletId], references: [id], onDelete: Cascade)
  menuId          String
  menu            Menu    @relation(fields: [menuId], references: [id], onDelete: Cascade)
  isEnabled       Boolean @default(true)
  overrideTimings Boolean @default(false)
  displayOrder    Int     @default(0)

  timingSlots OutletMenuTimingSlot[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([outletId, menuId])
  @@index([outletId, displayOrder])
  @@map("paynpik_outlet_menus")
}

model OutletMenuTimingSlot {
  id           String     @id @default(cuid())
  outletMenuId String
  outletMenu   OutletMenu @relation(fields: [outletMenuId], references: [id], onDelete: Cascade)
  dayOfWeek    Int
  startMinute  Int
  endMinute    Int

  @@index([outletMenuId, dayOfWeek])
  @@map("paynpik_outlet_menu_timing_slots")
}

enum FoodGrade {
  VEG
  NON_VEG
  VEGAN
}

model Item {
  id                    String      @id @default(cuid())
  name                  String
  description           String?
  shortDescription      String?     @db.VarChar(50)
  longDescription       String?     @db.VarChar(250)
  thumbnailUrl          String?
  imageUrl              String?     @db.Text
  basePrice             Decimal     @db.Decimal(10, 2)
  // Default GST % at item level. Used unless overridden per customer-tag or
  // per table-type (CustomerTagPrice.gstRate / TableTypePrice.gstRate). If
  // null, falls back to outlet's gstPercent.
  gstRate               Decimal?    @db.Decimal(5, 2)
  parcelAvailable       Boolean     @default(true)
  useCustomParcelCharge Boolean     @default(false)
  parcelCharge          Decimal?    @db.Decimal(10, 2)
  preparationTime       Int?
  foodGrade             FoodGrade   @default(VEG)
  isAvailable           Boolean     @default(true)
  isDisplayed           Boolean     @default(true)
  isPopular             Boolean     @default(false)
  isSpecial             Boolean     @default(false)
  // Limited-stock mode: when true, this item tracks `availableQuantity` and is
  // auto-flipped to isAvailable=false once stock hits 0. Outlet staff add stock
  // by incrementing (not replacing) via PATCH /items/:id/stock { addQuantity }.
  // When false, the item is unlimited and the count is ignored.
  hasLimitedStock       Boolean     @default(false)
  availableQuantity     Int         @default(0)
  displayOrder          Int         @default(0)
  subcategoryId         String
  subcategory           Subcategory @relation(fields: [subcategoryId], references: [id])

  kitchenStationId String?
  kitchenStation   KitchenStation? @relation(fields: [kitchenStationId], references: [id])

  // When true, this Item is a Bundle — at order time the server expands it
  // into its child rows (see ItemBundleChild). Bundles still live under a
  // subcategory and inherit every Item feature (variants, customer-tag /
  // table-type price overrides, visibility, limited stock, QR, etc.). The
  // only difference is the expansion at order time.
  isBundle            Boolean @default(false)
  // Customer-choice bundles: when set (>0), the customer must pick exactly
  // this many child rows out of the bundleChildren list at order time. Null
  // or 0 = legacy behavior (all children auto-included). Must be ≤ number
  // of configured children; admin form enforces this.
  maxBundleSelections Int?

  variants           Variant[]
  options            Option[]
  orderItems         OrderItem[]
  orderItemsAsBundle OrderItem[]        @relation("BundleParent")
  reviews            OrderItemReview[]
  tags               ItemTag[]
  customerTagPrices  CustomerTagPrice[]
  tableTypePrices    TableTypePrice[]
  images             ItemImage[]
  itemToppings       ItemTopping[]
  favorites          Favorite[]
  discounts          Discount[]
  bundleChildren     ItemBundleChild[]  @relation("BundleParentItem")
  bundleParentLinks  ItemBundleChild[]  @relation("BundleChildItem")
  offerBuyFor        Offer[]            @relation("OfferBuyItem")
  offerGetFor        Offer[]            @relation("OfferGetItem")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("paynpik_items")
}

model ItemImage {
  id           String @id @default(cuid())
  itemId       String
  item         Item   @relation(fields: [itemId], references: [id], onDelete: Cascade)
  url          String @db.Text
  displayOrder Int    @default(0)

  createdAt DateTime @default(now())

  @@index([itemId, displayOrder])
  @@map("paynpik_item_images")
}

model Variant {
  id               String  @id @default(cuid())
  name             String
  shortDescription String? @db.VarChar(80)
  price            Decimal @db.Decimal(10, 2)
  isAvailable      Boolean @default(true)
  itemId           String
  item             Item    @relation(fields: [itemId], references: [id])

  orderItems        OrderItem[]
  customerTagPrices CustomerTagPrice[]
  tableTypePrices   TableTypePrice[]
  bundleChildLinks  ItemBundleChild[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("paynpik_variants")
}

model Option {
  id     String  @id @default(cuid())
  name   String
  price  Decimal @default(0) @db.Decimal(10, 2)
  itemId String
  item   Item    @relation(fields: [itemId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("paynpik_options")
}

model ItemTag {
  id     String @id @default(cuid())
  name   String
  itemId String
  item   Item   @relation(fields: [itemId], references: [id])

  @@map("paynpik_item_tags")
}

model KitchenStation {
  id              String  @id @default(cuid())
  name            String
  isActive        Boolean @default(true)
  isMaster        Boolean @default(false)
  outletId        String
  outlet          Outlet  @relation(fields: [outletId], references: [id])
  currentWorkerId String?
  currentWorker   User?   @relation("StationWorker", fields: [currentWorkerId], references: [id], onDelete: SetNull)

  // Optional bluetooth printer this station prints its kitchen tickets to.
  // Multiple stations can point at the same printer (one shared printer in
  // the kitchen is the common case). Null = no printer assigned, so any
  // print action for this station no-ops with a friendly toast.
  printerId String?
  printer   Printer? @relation(fields: [printerId], references: [id], onDelete: SetNull)

  items Item[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("paynpik_kitchen_stations")
}

// Outlet-level catalog of printers (bluetooth-connected receipt printers in
// the kitchen). Stations bind to a printer via KitchenStation.printerId; one
// printer can serve many stations. Actual printing happens client-side via
// the Web Bluetooth API — the address/identifier is stored so the kitchen
// PWA knows which device to connect to.
model Printer {
  id         String  @id @default(cuid())
  outletId   String
  outlet     Outlet  @relation(fields: [outletId], references: [id], onDelete: Cascade)
  name       String
  // Connection type. Today only 'BLUETOOTH'; kept as a string column so we
  // can add wifi/USB later without an enum migration.
  connection String  @default("BLUETOOTH") @db.VarChar(20)
  // Device identifier — bluetooth MAC or Web-Bluetooth `deviceId`. Free-form
  // because the value is platform-dependent (Web Bluetooth returns an opaque
  // id, native bridges expose a MAC).
  address    String? @db.VarChar(128)
  // Optional printer model/notes for the admin's reference.
  model      String?
  isActive   Boolean @default(true)

  stations KitchenStation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([outletId])
  @@map("paynpik_printers")
}

// Conditional freebies: "spend ₹500 get a complementary sweet" or
// "buy 3 beers get 1 free at happy-hour". Distinct from Coupon (customer-
// selected at checkout) and Discount (price reduction on items/categories).
// Offers auto-trigger when a cart meets the rule and add a ₹0-priced line.
model Offer {
  id          String  @id @default(cuid())
  name        String
  description String?

  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  outletId   String?
  outlet     Outlet?  @relation(fields: [outletId], references: [id], onDelete: Cascade)

  // MIN_BILL: free item when cart subtotal >= minBillAmount
  // BUY_X_GET_Y: free `getQuantity` of `getItem` when cart has
  //   `buyQuantity` of `buyItem`
  triggerType   String   @db.VarChar(20)
  minBillAmount Decimal? @db.Decimal(10, 2)

  buyItemId    String?
  buyItem      Item?   @relation("OfferBuyItem", fields: [buyItemId], references: [id])
  buyVariantId String?
  buyQuantity  Int?

  getItemId    String?
  getItem      Item?   @relation("OfferGetItem", fields: [getItemId], references: [id])
  getVariantId String?
  getQuantity  Int?

  // Schedule
  validFrom   DateTime?
  validUntil  DateTime?
  daysOfWeek  String?   @db.VarChar(20) // CSV, ISO 1=Mon..7=Sun ("1,2,3,4,5")
  startMinute Int? // minutes-since-midnight
  endMinute   Int?

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([businessId])
  @@index([outletId])
  @@index([isActive])
  @@map("paynpik_offers")
}

// ─── Orders ──────────────────────────────────────────────

model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique
  tokenNumber     Int?
  status          OrderStatus @default(CREATED)
  isParcel        Boolean     @default(false)
  // True for Dine-in Postpaid orders: created without payment, accepts
  // additional items until `billRequestedAt` is set (Bill Now). Once set,
  // the order is locked and the Cash/UPI payment flow takes over.
  isPostpaid      Boolean     @default(false)
  billRequestedAt DateTime?
  notes           String?

  subtotal       Decimal @db.Decimal(10, 2)
  taxAmount      Decimal @default(0) @db.Decimal(10, 2)
  // SGST + CGST always sum to taxAmount; stored explicitly for cleaner
  // reporting / invoice display. For intra-state Indian GST they're 50/50.
  sgstAmount     Decimal @default(0) @db.Decimal(10, 2)
  cgstAmount     Decimal @default(0) @db.Decimal(10, 2)
  parcelAmount   Decimal @default(0) @db.Decimal(10, 2)
  discountAmount Decimal @default(0) @db.Decimal(10, 2)
  totalAmount    Decimal @db.Decimal(10, 2)

  outletId   String
  outlet     Outlet   @relation(fields: [outletId], references: [id])
  sectionId  String?
  section    Section? @relation(fields: [sectionId], references: [id])
  tableId    String?
  table      Table?   @relation(fields: [tableId], references: [id])
  customerId String?
  customer   User?    @relation("CustomerOrders", fields: [customerId], references: [id])
  staffId    String?
  staff      User?    @relation("StaffOrders", fields: [staffId], references: [id])

  // When non-null, this Order is a child of a ClusterOrder — created as part
  // of a cluster checkout where the customer placed one cart with items from
  // multiple outlets. The parent ClusterOrder holds the unified payment;
  // each child Order is what the outlet's kitchen sees and serves.
  clusterOrderId String?
  clusterOrder   ClusterOrder? @relation("ClusterChildren", fields: [clusterOrderId], references: [id])

  // Course sequencing (optional). Customer/staff can group items into
  // sequential courses ("Starter", "Main", "Dessert"). `activeSequence`
  // tracks which course is currently released to the kitchen. Items with
  // a higher sequenceNumber are held until prior courses are SERVED, at
  // which point activeSequence auto-advances. `sequenceLabels` stores the
  // display name per course as JSON, e.g. {"1":"Starter","2":"Main"}.
  // Items with sequenceNumber=null are always active (default behaviour).
  activeSequence Int   @default(1)
  sequenceLabels Json?

  items          OrderItem[]
  payments       Payment[]
  statusHistory  OrderStatusHistory[]
  disputes       Dispute[]
  customerAlerts CustomerAlert[]
  couponUsages   CouponUsage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("paynpik_orders")
}

// ─── Cluster (food court / theatre roof) ─────────────────

// Join row linking a member outlet to the cluster (host) business. The
// outletId is UNIQUE so an outlet can be in at most one cluster at any time
// — the "cluster-exclusive while linked" rule. Removing this row releases
// the outlet back to standalone operation.
model ClusterMember {
  id                String   @id @default(cuid())
  clusterBusinessId String
  clusterBusiness   Business @relation("ClusterMembership", fields: [clusterBusinessId], references: [id], onDelete: Cascade)
  outletId          String   @unique
  outlet            Outlet   @relation("OutletClusterMembership", fields: [outletId], references: [id])
  displayOrder      Int      @default(0)
  joinedAt          DateTime @default(now())

  @@index([clusterBusinessId, displayOrder])
  @@map("paynpik_cluster_members")
}

// Parent record for a single customer checkout that spans multiple outlets in
// a cluster. The customer's payment lands here; child Orders (one per outlet)
// inherit clusterOrderId and surface independently to each outlet's kitchen.
// routeTransfers is a JSON array — one entry per child order with the
// computed split { outletId, orderId, amount, razorpayLinkedAccountId,
// transferId?, status }. In stubbed test mode the transfer is recorded but
// not actually executed against Razorpay.
model ClusterOrder {
  id                 String   @id @default(cuid())
  clusterOrderNumber String   @unique
  clusterBusinessId  String
  clusterBusiness    Business @relation("ClusterOrders", fields: [clusterBusinessId], references: [id])
  customerId         String?
  customer           User?    @relation("CustomerClusterOrders", fields: [customerId], references: [id])
  // The cluster's shared seating table, if the customer scanned a table QR.
  // Stored as plain string rather than FK because cluster tables may belong
  // to any member outlet — the child Order keeps the canonical FK.
  tableId            String?

  subtotal     Decimal @db.Decimal(10, 2)
  taxAmount    Decimal @default(0) @db.Decimal(10, 2)
  parcelAmount Decimal @default(0) @db.Decimal(10, 2)
  totalAmount  Decimal @db.Decimal(10, 2)

  // 'RAZORPAY' (real gateway) or 'BYPASS' (testing). Kept as a free-form
  // string rather than extending the hot PaymentMode enum used by the
  // single-outlet Payment model.
  paymentMethod     String?       @db.VarChar(20)
  paymentStatus     PaymentStatus @default(PENDING)
  razorpayOrderId   String?
  razorpayPaymentId String?
  razorpaySignature String?       @db.Text
  routeTransfers    Json          @default("[]")

  childOrders Order[] @relation("ClusterChildren")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clusterBusinessId])
  @@index([customerId])
  @@map("paynpik_cluster_orders")
}

model OrderItem {
  id         String          @id @default(cuid())
  quantity   Int
  unitPrice  Decimal         @db.Decimal(10, 2)
  totalPrice Decimal         @db.Decimal(10, 2)
  // Resolved GST % captured at order time (sticky against future config changes).
  gstRate    Decimal         @default(0) @db.Decimal(5, 2)
  gstAmount  Decimal         @default(0) @db.Decimal(10, 2)
  notes      String?
  status     OrderItemStatus @default(PENDING)
  orderId    String
  order      Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  itemId     String
  item       Item            @relation(fields: [itemId], references: [id])
  variantId  String?
  variant    Variant?        @relation(fields: [variantId], references: [id])

  // Menu snapshot — resolved at order-time via item->subcategory->category.menuId.
  // Frozen even if the category later moves to a different menu, so historical
  // receipts keep their original grouping. Nullable for legacy rows.
  menuId String?
  menu   Menu?   @relation(fields: [menuId], references: [id])

  // When the customer ordered a Bundle (an Item flagged isBundle=true), the
  // row was created by expanding the bundle into its child items — all
  // child rows share the same bundleId (= the parent Item.id) so the
  // kitchen ticket + receipt can group them under the bundle's name. Only
  // the first child carries the bundle's price; siblings have totalPrice=0.
  bundleId     String?
  bundleParent Item?   @relation("BundleParent", fields: [bundleId], references: [id])

  // Course position (1-based). Null = no sequencing applied — the item is
  // always live. See Order.activeSequence for the gating rule.
  sequenceNumber Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  review OrderItemReview?

  @@index([menuId])
  @@index([bundleId])
  @@map("paynpik_order_items")
}

// ─── Reviews ──────────────────────────────────────��────────────
// Per-OrderItem customer rating (1-5) + optional comment. itemId is
// denormalized so the menu can compute aggregates without joining through
// Order. Owner reply + payback fields are added in Phase B.
model OrderItemReview {
  id          String    @id @default(cuid())
  orderItemId String    @unique
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  itemId      String
  item        Item      @relation(fields: [itemId], references: [id])
  customerId  String
  customer    User      @relation("ReviewByCustomer", fields: [customerId], references: [id])
  rating      Int
  comment     String?   @db.Text

  // Owner/manager response. Reply is optional; once set, repliedAt is too.
  replyText     String?   @db.Text
  replyByUserId String?
  replyBy       User?     @relation("ReviewReplyBy", fields: [replyByUserId], references: [id])
  repliedAt     DateTime?

  // Payback: links to a Payment row marked isRefund=true. paybackAmount is
  // duplicated for fast reads; the Payment row is the source of truth.
  paybackAmount    Decimal? @db.Decimal(10, 2)
  paybackPaymentId String?  @unique
  paybackPayment   Payment? @relation(fields: [paybackPaymentId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([itemId])
  @@index([customerId])
  @@map("paynpik_order_item_reviews")
}

model OrderStatusHistory {
  id        String      @id @default(cuid())
  status    OrderStatus
  changedBy String?
  notes     String?
  orderId   String
  order     Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@map("paynpik_order_status_history")
}

model Payment {
  id              String        @id @default(cuid())
  amount          Decimal       @db.Decimal(10, 2)
  mode            PaymentMode
  status          PaymentStatus @default(PENDING)
  // Record-only refund: when an outlet records a payback against a customer
  // review, we mint a Payment with isRefund=true and link it from the review.
  // The mode (CASH/UPI/...) still records how the money was actually returned.
  isRefund        Boolean       @default(false)
  gatewayRef      String?
  gatewayResponse Json?
  orderId         String
  order           Order         @relation(fields: [orderId], references: [id])

  reviewPayback OrderItemReview?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("paynpik_payments")
}

model Dispute {
  id          String   @id @default(cuid())
  description String
  claimAmount Decimal? @db.Decimal(10, 2)
  status      String   @default("OPEN")
  resolution  String?
  // Stored as Json (array of URL strings) since MySQL lacks native array types.
  attachments Json     @default("[]")
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("paynpik_disputes")
}

// ─── Inventory ───────────────────────────────────────────

model MaterialCategory {
  id         String             @id @default(cuid())
  name       String
  businessId String
  parentId   String?
  parent     MaterialCategory?  @relation("CategoryTree", fields: [parentId], references: [id])
  children   MaterialCategory[] @relation("CategoryTree")
  materials  Material[]

  @@map("paynpik_material_categories")
}

model Material {
  id           String            @id @default(cuid())
  name         String
  unit         String
  currentStock Decimal           @default(0) @db.Decimal(10, 3)
  reorderLevel Decimal?          @db.Decimal(10, 3)
  costPerUnit  Decimal?          @db.Decimal(10, 2)
  businessId   String
  business     Business          @relation(fields: [businessId], references: [id])
  categoryId   String?
  category     MaterialCategory? @relation(fields: [categoryId], references: [id])

  purchaseOrders PurchaseOrder[]
  consumptions   ConsumptionLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("paynpik_materials")
}

model Vendor {
  id         String   @id @default(cuid())
  name       String
  gstNumber  String?
  phone      String?
  email      String?
  address    String?
  isActive   Boolean  @default(true)
  businessId String
  business   Business @relation(fields: [businessId], references: [id])

  purchaseOrders PurchaseOrder[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("paynpik_vendors")
}

model PurchaseOrder {
  id            String   @id @default(cuid())
  poNumber      String   @unique
  quantity      Decimal  @db.Decimal(10, 3)
  unitPrice     Decimal  @db.Decimal(10, 2)
  totalAmount   Decimal  @db.Decimal(10, 2)
  status        String   @default("PENDING")
  paymentStatus String   @default("UNPAID")
  vendorId      String
  vendor        Vendor   @relation(fields: [vendorId], references: [id])
  materialId    String
  material      Material @relation(fields: [materialId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("paynpik_purchase_orders")
}

model ConsumptionLog {
  id         String   @id @default(cuid())
  quantity   Decimal  @db.Decimal(10, 3)
  purpose    String?
  issuedBy   String?
  materialId String
  material   Material @relation(fields: [materialId], references: [id])

  createdAt DateTime @default(now())

  @@map("paynpik_consumption_logs")
}

// ─── Subscriptions & Billing ─────────────────────────────

model Plan {
  id               String  @id @default(cuid())
  name             String
  description      String?
  monthlyCost      Decimal @db.Decimal(10, 2)
  annualCost       Decimal @db.Decimal(10, 2)
  maxOutlets       Int
  maxUsers         Int
  transactionLimit Int?
  storageLimit     Int?
  features         Json
  isActive         Boolean @default(true)

  subscriptions Subscription[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("paynpik_plans")
}

model Subscription {
  id        String             @id @default(cuid())
  status    SubscriptionStatus @default(TRIAL)
  startDate DateTime
  endDate   DateTime
  autoRenew Boolean            @default(true)
  planId    String
  plan      Plan               @relation(fields: [planId], references: [id])

  business Business?
  invoices Invoice[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("paynpik_subscriptions")
}

model Invoice {
  id             String       @id @default(cuid())
  amount         Decimal      @db.Decimal(10, 2)
  gstAmount      Decimal      @db.Decimal(10, 2)
  totalAmount    Decimal      @db.Decimal(10, 2)
  status         String       @default("PENDING")
  dueDate        DateTime
  paidAt         DateTime?
  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id])

  createdAt DateTime @default(now())

  @@map("paynpik_invoices")
}

// ─── Marketing leads ────────────────────────────────────

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  CONVERTED
  LOST
}

model Lead {
  id             String     @id @default(cuid())
  name           String
  restaurantName String
  phone          String
  email          String?
  outletCount    Int?
  businessType   String?
  message        String?
  source         String?    @default("landing-page")
  status         LeadStatus @default(NEW)
  notes          String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
  @@map("paynpik_leads")
}

// ─── Customer tags & tag-based pricing ────────────────────

model CustomerTag {
  id       String @id @default(cuid())
  name     String
  color    String @default("#f97316")
  outletId String
  outlet   Outlet @relation(fields: [outletId], references: [id], onDelete: Cascade)

  itemPrices  CustomerTagPrice[]
  assignments CustomerTagAssignment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([outletId, name])
  @@map("paynpik_customer_tags")
}

model CustomerTagPrice {
  id            String      @id @default(cuid())
  itemId        String
  item          Item        @relation(fields: [itemId], references: [id], onDelete: Cascade)
  variantId     String?
  variant       Variant?    @relation(fields: [variantId], references: [id], onDelete: Cascade)
  customerTagId String
  customerTag   CustomerTag @relation(fields: [customerTagId], references: [id], onDelete: Cascade)
  price         Decimal     @db.Decimal(10, 2)
  // Optional GST % override for this (item, customerTag). null = use item.gstRate.
  gstRate       Decimal?    @db.Decimal(5, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([itemId, variantId, customerTagId])
  @@map("paynpik_customer_tag_prices")
}

model CustomerTagAssignment {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation("UserCustomerTagAssignments", fields: [userId], references: [id], onDelete: Cascade)
  outletId      String
  outlet        Outlet      @relation("OutletCustomerTagAssignments", fields: [outletId], references: [id], onDelete: Cascade)
  customerTagId String
  customerTag   CustomerTag @relation(fields: [customerTagId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, outletId])
  @@map("paynpik_customer_tag_assignments")
}

// ─── Toppings (outlet-level catalog) ──────────────────────

model Topping {
  id           String  @id @default(cuid())
  name         String
  basePriceAdd Decimal @default(0) @db.Decimal(10, 2)
  outletId     String
  outlet       Outlet  @relation(fields: [outletId], references: [id], onDelete: Cascade)

  options   ToppingOption[]
  itemLinks ItemTopping[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([outletId, name])
  @@map("paynpik_toppings")
}

model ToppingOption {
  id           String  @id @default(cuid())
  toppingId    String
  topping      Topping @relation(fields: [toppingId], references: [id], onDelete: Cascade)
  name         String
  priceAdd     Decimal @default(0) @db.Decimal(10, 2)
  displayOrder Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("paynpik_topping_options")
}

model ItemTopping {
  id         String   @id @default(cuid())
  itemId     String
  item       Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  toppingId  String
  topping    Topping  @relation(fields: [toppingId], references: [id], onDelete: Cascade)
  priceAdd   Decimal? @db.Decimal(10, 2)
  isRequired Boolean  @default(false)

  createdAt DateTime @default(now())

  @@unique([itemId, toppingId])
  @@map("paynpik_item_toppings")
}

// ─── Outlet imagery + hours ───────────────────────────────

model OutletImage {
  id           String @id @default(cuid())
  outletId     String
  outlet       Outlet @relation(fields: [outletId], references: [id], onDelete: Cascade)
  url          String @db.Text
  displayOrder Int    @default(0)

  createdAt DateTime @default(now())

  @@index([outletId, displayOrder])
  @@map("paynpik_outlet_images")
}

// Multiple rows per (outlet, dayOfWeek) = multiple open ranges.
// No rows for a day = closed that day.
// dayOfWeek: 0=Sun … 6=Sat
model OutletHour {
  id        String @id @default(cuid())
  outletId  String
  outlet    Outlet @relation(fields: [outletId], references: [id], onDelete: Cascade)
  dayOfWeek Int
  openTime  String // "HH:MM"
  closeTime String // "HH:MM"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([outletId, dayOfWeek])
  @@map("paynpik_outlet_hours")
}

model Favorite {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  itemId String
  item   Item   @relation(fields: [itemId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, itemId])
  @@index([userId])
  @@map("paynpik_favorites")
}

// ─── Manually-added customers (per outlet) ────────────────
model OutletCustomer {
  id       String @id @default(cuid())
  outletId String
  outlet   Outlet @relation("OutletCustomerLinks", fields: [outletId], references: [id], onDelete: Cascade)
  userId   String
  user     User   @relation("UserOutletLinks", fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([outletId, userId])
  @@index([outletId])
  @@map("paynpik_outlet_customers")
}

// ─── Table types (outlet-level) + per-item pricing ────────

model TableType {
  id       String @id @default(cuid())
  name     String
  color    String @default("#0ea5e9")
  outletId String
  outlet   Outlet @relation(fields: [outletId], references: [id], onDelete: Cascade)

  tables          Table[]
  prices          TableTypePrice[]
  serviceStations ServiceStation[]
  menus           TableTypeMenu[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([outletId, name])
  @@map("paynpik_table_types")
}

// Per-section menu visibility. One row per (TableType × Menu) pair where
// isEnabled toggles whether the menu is offered to customers seated in that
// section. The default Menu is always considered enabled regardless of this
// row — the API layer rejects disabling it. Rows for non-default menus
// default isEnabled=true, so existing behavior is preserved when the feature
// goes live.
model TableTypeMenu {
  id          String    @id @default(cuid())
  tableTypeId String
  tableType   TableType @relation(fields: [tableTypeId], references: [id], onDelete: Cascade)
  menuId      String
  menu        Menu      @relation(fields: [menuId], references: [id], onDelete: Cascade)
  isEnabled   Boolean   @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tableTypeId, menuId])
  @@index([menuId])
  @@map("paynpik_table_type_menus")
}

model TableTypePrice {
  id          String    @id @default(cuid())
  itemId      String
  item        Item      @relation(fields: [itemId], references: [id], onDelete: Cascade)
  variantId   String?
  variant     Variant?  @relation(fields: [variantId], references: [id], onDelete: Cascade)
  tableTypeId String
  tableType   TableType @relation(fields: [tableTypeId], references: [id], onDelete: Cascade)
  price       Decimal   @db.Decimal(10, 2)
  // Optional GST % override for this (item, tableType). null = use item.gstRate.
  gstRate     Decimal?  @db.Decimal(5, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([itemId, variantId, tableTypeId])
  @@map("paynpik_table_type_prices")
}

// ─── Service stations (outlet-level) ─────────────────────
// Floor counterpart of KitchenStation: service staff (supervisor + service
// persons) are grouped into a station that's pinned to one TableType and a
// specific subset of tables under that type. Orders for those tables become
// visible to the station's workers.
model ServiceStation {
  id          String     @id @default(cuid())
  name        String
  isActive    Boolean    @default(true)
  outletId    String
  outlet      Outlet     @relation(fields: [outletId], references: [id], onDelete: Cascade)
  tableTypeId String?
  tableType   TableType? @relation(fields: [tableTypeId], references: [id], onDelete: SetNull)

  // When true this station handles parcel orders (isParcel=true) instead of
  // table-bound service. Parcel stations don't bind to a tableType/tables
  // because the work is "package it and hand it to the customer at the
  // counter." If no parcel station has an active worker, parcel orders fall
  // back to whichever regular service station covers the order.
  isParcelStation Boolean @default(false)

  workers ServiceStationWorker[]
  tables  ServiceStationTable[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([outletId])
  @@map("paynpik_service_stations")
}

model ServiceStationWorker {
  id        String         @id @default(cuid())
  stationId String
  station   ServiceStation @relation(fields: [stationId], references: [id], onDelete: Cascade)
  userId    String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([stationId, userId])
  @@map("paynpik_service_station_workers")
}

model ServiceStationTable {
  id        String         @id @default(cuid())
  stationId String
  station   ServiceStation @relation(fields: [stationId], references: [id], onDelete: Cascade)
  tableId   String
  table     Table          @relation(fields: [tableId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([stationId, tableId])
  @@map("paynpik_service_station_tables")
}

// ─── Customer alerts feed (in-app fallback when WhatsApp not configured) ──
// Always written by the lifecycle dispatcher, regardless of whether the
// WhatsApp send succeeded — so the customer sees the same message under
// "Alerts" in the customer app. `sentVia` records how it was delivered:
// IN_APP, WHATSAPP, or BOTH.
model CustomerAlert {
  id            String   @id @default(cuid())
  customerId    String
  customer      User     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  orderId       String?
  order         Order?   @relation(fields: [orderId], references: [id], onDelete: SetNull)
  orderItemId   String? // not FK'd — order items are mutable and may be cancelled
  trigger       String // e.g. ORDER_PLACED, PAYMENT_RECEIVED, ITEM_READY
  title         String
  body          String   @db.Text
  ringtone      String? // resolved at send-time from User.alertRingtone
  sentVia       String   @default("IN_APP") // IN_APP | WHATSAPP | BOTH
  whatsappError String?
  isRead        Boolean  @default(false)
  createdAt     DateTime @default(now())

  @@index([customerId])
  @@index([orderId])
  @@index([isRead])
  @@map("paynpik_customer_alerts")
}

// ─── 3rd-party integration provider credentials (platform-managed) ──
// Each row is one configured provider for one channel — e.g.
// (WHATSAPP, "GUPSHUP"), (SMS, "TWILIO"), (PAYMENT_GATEWAY, "RAZORPAY").
// `config` holds opaque credentials (api keys, secrets, sender ids, etc.)
// kept as JSON so each provider can have its own shape without schema churn.
model IntegrationConfig {
  id           String             @id @default(cuid())
  channel      IntegrationChannel
  providerKey  String // stable key, e.g. "RAZORPAY", "GUPSHUP"
  providerName String // display name
  isDefault    Boolean            @default(false)
  isActive     Boolean            @default(true)
  config       Json               @default("{}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([channel, providerKey])
  @@index([channel, isDefault])
  @@map("paynpik_integration_configs")
}

// ─── Messaging templates (WhatsApp / SMS / Email) ───────
// Templates can be authored at three scopes:
//   PLATFORM  — boilerplate available to every business (businessId/outletId null)
//   BUSINESS  — created by a Business Owner, visible to that business's outlets
//   OUTLET    — created by an Outlet Admin, scoped to one outlet
// Approval flow runs through the platform admin; see TemplateApprovalStatus.
model MessageTemplate {
  id        String           @id @default(cuid())
  scope     TemplateScope
  channel   TemplateChannel
  name      String // human-friendly slug, unique within scope
  category  TemplateCategory @default(TRANSACTIONAL)
  trigger   String? // optional: ORDER_PLACED | ORDER_READY | PAYMENT_RECEIVED | CUSTOM
  language  String           @default("en")
  body      String           @db.Text
  // Json array of {{var}} names extracted from the body. Json instead of
  // String[] because MySQL has no native array type.
  variables Json             @default("[]")

  approvalStatus     TemplateApprovalStatus @default(DRAFT)
  providerKey        String? // resolved provider that approved it (e.g. "GUPSHUP")
  providerTemplateId String? // id returned by provider once live
  submittedAt        DateTime?
  reviewedAt         DateTime?
  rejectionReason    String?

  businessId  String?
  business    Business? @relation(fields: [businessId], references: [id], onDelete: Cascade)
  outletId    String?
  outlet      Outlet?   @relation(fields: [outletId], references: [id], onDelete: Cascade)
  createdById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([scope, channel, approvalStatus])
  @@index([businessId])
  @@index([outletId])
  @@map("paynpik_message_templates")
}

// ─── Idempotency (Layer 2 outbox / write deduplication) ────
// Short-lived cache of write responses keyed by client-supplied
// Idempotency-Key header. The IdempotencyInterceptor consults this
// table on every incoming write; a hit replays the cached body so
// retries from the client outbox can never duplicate a side-effect
// (e.g. a customer placing the same order twice on a flaky network).
model IdempotencyKey {
  id         String   @id @default(cuid())
  key        String   @unique
  scope      String   @db.VarChar(191) // e.g. POST /outlets/:id/orders
  statusCode Int
  body       Json
  createdAt  DateTime @default(now())
  expiresAt  DateTime

  @@index([expiresAt])
  @@map("paynpik_idempotency_keys")
}

// ─── Promotions ──────────────────────────────────────────────────
// Pricing waterfall at checkout (customer-side phase will wire this):
//   1. Item / category / subcategory discounts (auto)
//   2. Bill-level discount (auto, if conditions match)
//   3. Bundle prices (a Bundle is a sellable composite item)
//   4. Offers — conditional freebies (auto, add a ₹0 line)
//   5. Coupon — one per bill, customer-selected
//   6. Reward redemption — customer chooses how many points to burn

// Coupons: customer-selected promotions. Business or outlet scope; can be
// targeted at a specific list of customers or open to all. Carry usage
// caps (per-customer and total).
model Coupon {
  id          String  @id @default(cuid())
  code        String  @db.VarChar(50)
  name        String
  description String?

  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  outletId   String?
  outlet     Outlet?  @relation(fields: [outletId], references: [id], onDelete: Cascade)

  discountType      String   @db.VarChar(10) // PERCENT | FIXED
  discountValue     Decimal  @db.Decimal(10, 2)
  minBillAmount     Decimal? @db.Decimal(10, 2)
  maxDiscountAmount Decimal? @db.Decimal(10, 2)

  validFrom          DateTime
  validUntil         DateTime
  maxUsesPerCustomer Int      @default(1)
  maxTotalUses       Int?
  usesCount          Int      @default(0)

  // ALL: any customer ordering at the outlet may pick it.
  // SPECIFIC: only customers listed in targetCustomers may pick it.
  targetType String  @default("ALL") @db.VarChar(10)
  isActive   Boolean @default(true)

  targetCustomers CouponCustomer[]
  usages          CouponUsage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([businessId])
  @@index([outletId])
  @@index([code])
  @@index([isActive, validFrom, validUntil])
  @@map("paynpik_coupons")
}

model CouponCustomer {
  id       String @id @default(cuid())
  couponId String
  coupon   Coupon @relation(fields: [couponId], references: [id], onDelete: Cascade)
  userId   String
  user     User   @relation("CouponTargets", fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([couponId, userId])
  @@index([userId])
  @@map("paynpik_coupon_customers")
}

model CouponUsage {
  id             String   @id @default(cuid())
  couponId       String
  coupon         Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  userId         String
  user           User     @relation("CouponUsages", fields: [userId], references: [id])
  orderId        String?
  order          Order?   @relation(fields: [orderId], references: [id])
  clusterOrderId String?
  discountAmount Decimal  @db.Decimal(10, 2)
  appliedAt      DateTime @default(now())

  @@index([couponId])
  @@index([userId])
  @@index([orderId])
  @@map("paynpik_coupon_usages")
}

// Discounts: scheduled price reductions on a category / subcategory /
// item / whole-bill. Auto-apply when their day-of-week + time window
// matches at order time. isManualOnly = preconfigured counter discount
// that the cashier picks from a list at checkout.
model Discount {
  id   String @id @default(cuid())
  name String

  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  outletId   String?
  outlet     Outlet?  @relation(fields: [outletId], references: [id], onDelete: Cascade)

  // Target — exactly one of categoryId / subcategoryId / itemId is set for
  // CATEGORY / SUBCATEGORY / ITEM. All three null for BILL. Validated in
  // service layer.
  targetType    String       @db.VarChar(20) // CATEGORY | SUBCATEGORY | ITEM | BILL
  categoryId    String?
  category      Category?    @relation(fields: [categoryId], references: [id])
  subcategoryId String?
  subcategory   Subcategory? @relation(fields: [subcategoryId], references: [id])
  itemId        String?
  item          Item?        @relation(fields: [itemId], references: [id])

  discountType      String   @db.VarChar(10) // PERCENT | FIXED
  discountValue     Decimal  @db.Decimal(10, 2)
  minBillAmount     Decimal? @db.Decimal(10, 2) // only meaningful for BILL
  maxDiscountAmount Decimal? @db.Decimal(10, 2)

  validFrom   DateTime?
  validUntil  DateTime?
  daysOfWeek  String?   @db.VarChar(20) // CSV, ISO 1=Mon..7=Sun
  startMinute Int?
  endMinute   Int?

  // Counter / management discount — picked from a preconfigured list by the
  // cashier instead of auto-applying. Pair with the manager-PIN-gated
  // free-form override (UI-side; no schema row needed for the free-form path).
  isManualOnly Boolean @default(false)
  isActive     Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([businessId])
  @@index([outletId])
  @@index([targetType])
  @@index([categoryId])
  @@index([subcategoryId])
  @@index([itemId])
  @@index([isActive, validFrom, validUntil])
  @@map("paynpik_discounts")
}

// Bundles: a fixed-price composite "item" composed of one or more child
// items (with optional variants). Surfaces in the menu alongside regular
// items. When ordered, child items still need to route to their kitchen
// stations — the customer-side phase will wire that.
// Bundle composition. The parent Item (with isBundle=true) acts as the
// sellable line on the menu — it carries the price, food grade, images,
// short/long description, customer-tag prices, table-type prices, limited
// stock and QR. The children listed here are what the kitchen actually
// prepares when a customer orders the bundle.
//
// Quantities multiply: ordering 2 of a bundle whose child entry says
// quantity=3 expands to 6 prep tickets for that child.
model ItemBundleChild {
  id           String   @id @default(cuid())
  parentItemId String
  parentItem   Item     @relation("BundleParentItem", fields: [parentItemId], references: [id], onDelete: Cascade)
  childItemId  String
  childItem    Item     @relation("BundleChildItem", fields: [childItemId], references: [id])
  // Optional variant pin — if the bundle includes "Coffee — Large", store
  // the variant id here. Null = the child item's default (variant-less).
  variantId    String?
  variant      Variant? @relation(fields: [variantId], references: [id])
  quantity     Int      @default(1)
  displayOrder Int      @default(0)

  createdAt DateTime @default(now())

  @@index([parentItemId])
  @@index([childItemId])
  @@map("paynpik_item_bundle_children")
}

// Rewards — platform-wide singleton config + per-customer running balance
// + ledger of every earn/redeem/expire/adjust transaction.
//
// Balance is global per customer (credit-card style): points earned at any
// outlet/business apply to a single balance. Earn rate + redeem rate are
// platform-wide; an outlet can opt out of accepting redemptions via
// Outlet.acceptRewardRedemption.
model RewardConfig {
  id                   String  @id @default("default")
  // Points earned per ₹1 of order subtotal. e.g., 0.10 → 1 point per ₹10.
  earnRate             Decimal @default(0.1) @db.Decimal(8, 4)
  // ₹ value per 1 point. e.g., 1.0 → 1 point = ₹1.
  redeemRate           Decimal @default(1) @db.Decimal(8, 4)
  // Minimum points needed to redeem at all.
  minRedemptionPoints  Int     @default(50)
  // Cap on what % of a bill can be paid via points (0–100).
  maxRedemptionPercent Decimal @default(50) @db.Decimal(5, 2)
  // Days after which earned points expire. Null = never.
  expiryDays           Int?
  isActive             Boolean @default(true)

  updatedAt DateTime @updatedAt

  @@map("paynpik_reward_config")
}

model CustomerRewardAccount {
  id               String @id @default(cuid())
  userId           String @unique
  user             User   @relation("RewardAccount", fields: [userId], references: [id], onDelete: Cascade)
  balance          Int    @default(0)
  lifetimeEarned   Int    @default(0)
  lifetimeRedeemed Int    @default(0)

  transactions RewardTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("paynpik_reward_accounts")
}

model RewardTransaction {
  id        String                @id @default(cuid())
  accountId String
  account   CustomerRewardAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  userId    String
  user      User                  @relation("RewardTransactions", fields: [userId], references: [id])

  // EARN | REDEEM | EXPIRE | ADJUST
  type         String   @db.VarChar(10)
  // Positive for earn / ADJUST+, negative for redeem / expire / ADJUST−.
  points       Int
  // ₹ value of the redemption when type=REDEEM (null otherwise).
  amountValue  Decimal? @db.Decimal(10, 2)
  balanceAfter Int

  orderId        String?
  clusterOrderId String?
  outletId       String?

  notes     String?
  expiresAt DateTime? // only set for EARN

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([accountId])
  @@index([orderId])
  @@index([expiresAt])
  @@map("paynpik_reward_transactions")
}
