# Copy to .env on the server and fill in real values.

# --- Server ---
NODE_ENV=production
PORT=3001

# --- Database (MySQL) ---
DATABASE_URL=mysql://paynpik:paynpik_pass@127.0.0.1:3306/paynpik_db

# --- Redis (Bull queues + caches) ---
REDIS_URL=redis://127.0.0.1:6379
# Set these when the Redis instance requires auth and you'd rather not
# embed credentials in REDIS_URL (hosted providers — Upstash, Redis Cloud,
# ElastiCache with ACL, etc.). When set, they override any credentials
# already in REDIS_URL.
REDIS_PASSWORD=
REDIS_USERNAME=

# --- Auth ---
JWT_SECRET=replace-me
JWT_EXPIRES_IN=7d

# --- CORS (must match the deployed admin + customer origins) ---
FRONTEND_URL=https://admin.yourdomain.com
CUSTOMER_URL=https://order.yourdomain.com

# --- Razorpay ---
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# --- Messaging integrations (optional) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
SENDGRID_API_KEY=

# --- AWS S3 (optional, for uploads) ---
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=

# --- Elasticsearch (optional) ---
ELASTICSEARCH_URL=
