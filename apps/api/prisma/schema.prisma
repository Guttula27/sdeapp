generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// Recommended production DATABASE_URL params (append to the URL):
//   ?connection_limit=20&pool_timeout=10
//
// Why: Prisma's default pool is `num_cpus × 2 + 1` — on a typical 4-core
// container that's 9 connections. Under burst load (e.g. a kitchen-screen
// reconnect storm or a menu cache cold-fill) Prisma serialises new queries
// once the pool is exhausted, surfacing as request-side latency spikes
// before any single query is actually slow. Bumping to 20 buys headroom
// and the 10 s pool_timeout fails fast instead of hanging.
//
// MySQL's own `max_connections` ceiling is the hard limit — keep
// (connection_limit × api_replicas) < max_connections. Local dev keeps
// the default; this only matters in deployed environments.
// ─────────────────────────────────────────────────────────────

// ─── Enums ───────────────────────────────────────────────

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

// Visibility scope for staff users — controls which admin staff list
// a user appears on. See User.ownerScope for the full semantics.
enum UserOwnerScope {
  PLATFORM
  BUSINESS
  OUTLET
}

// How an item is sold. NUMBER (default) = count-based — qty is "how
// many of this dish". GRAMS / MILLILITERS = portion-based — the item's
// variants represent fixed portion sizes (e.g. 100g, 250g, 500g) and
// the customer picks which portion. Drives admin form layout + how
// the variant name is auto-formatted.
enum ItemQuantityUnit {
  NUMBER
  GRAMS
  MILLILITERS
}

enum BusinessType {
  RESTAURANT
  QSR
  FOOD_COURT
  CAFETERIA
  PARCEL_OUTLET
  DINE_IN
  HYBRID
}

enum OutletType {
  SELF_SERVICE
  SELF_SERVICE_PARCEL
  DINE_IN_PREPAID
  DINE_IN_POSTPAID
  HYBRID
}

enum OrderStatus {
  CREATED
  QUEUED
  PREPARING
  READY
  // Parcel-path service step: kitchen finished, parcel station is packaging
  // / staging it. Customer gets a "ready for pickup" alert on entry. Maps
  // to the same point in the lifecycle as OUT_FOR_SERVICE for table service.
  READY_FOR_PICKUP
  OUT_FOR_SERVICE
  SERVED
  CANCELLED
  DISPUTED
  RESOLVED
  FOR_REFUND
  REFUND_COMPLETE
}

enum OrderItemStatus {
  // Postpaid additions sit here until service desk confirms with the
  // customer that the line is correct. Kitchen never sees items in
  // this state. Verifying moves them to PENDING.
  PENDING_VERIFICATION
  PENDING
  PREPARING
  READY
  // Parcel-only intermediate: kitchen finished a dish (READY) and the
  // parcel desk has boxed it. Once every live item is PACKED the order
  // auto-rolls to READY_FOR_PICKUP and the customer is notified.
  // Non-parcel orders skip this state — items go READY → SERVED.
  PACKED
  SERVED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum PaymentMode {
  UPI
  CARD
  CASH
  WALLET
  NET_BANKING
}

enum OutletShiftStatus {
  ACTIVE
  CLOSED
}

enum CashierShiftStatus {
  ACTIVE
  CLOSED
}

enum RefundStatus {
  INITIATED // Cashier filed it; awaiting approval
  APPROVED // Approver OK'd; cash refunds complete here, gateway refunds move to PROCESSING
  PROCESSING // Razorpay refund API in flight
  COMPLETED // Money returned to customer
  FAILED // Razorpay rejected or processing errored
  CANCELLED // Cancelled before completion
}

// Lifecycle of a single split-bill share. Each share is independent —
// one diner's WhatsApp-delivered sub-bill against a parent Order.
enum SplitShareStatus {
  PENDING // Row created; WhatsApp not yet dispatched
  SENT // WhatsApp delivered to the diner's phone
  VIEWED // Diner opened the share detail in the customer PWA
  PAID // Payment row materialised against the share
  CANCELLED // Operator cancelled before payment
  EXPIRED // Auto-expired by the reminder/expiry job (Phase B)
}

enum SplitFeeAbsorption {
  OUTLET // Default — outlet eats the Razorpay fee, diner pays exactly their share
  CUSTOMER // Diner pays share + Razorpay convenience fee + GST on the fee
}

// Order origin / aggregator channel. DIRECT = walk-in, customer PWA,
// QR scan — the existing flow. Other values mark orders that came
// inbound from a third-party marketplace, so reports + the kitchen
// header can call them out and we can sync status back to the right
// provider.
enum AggregatorChannel {
  DIRECT
  ZOMATO
  SWIGGY
  UBER_EATS
}

enum AggregatorOrderStatus {
  RECEIVED // Inbound webhook fired; we've recorded it
  ACCEPTED // We accepted; the kitchen is on it
  REJECTED // We declined (out of stock, closed, etc.)
  PREPARING
  READY
  DISPATCHED // Rider picked up
  DELIVERED // Aggregator told us delivery happened
  CANCELLED
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  EXPIRED
  SUSPENDED
}

enum QRType {
  TABLE
  OUTLET
  CUSTOMER
  PAYMENT
}

// ─── 3rd-party integrations & messaging ──────────────────
enum IntegrationChannel {
  WHATSAPP
  SMS
  EMAIL
  PAYMENT_GATEWAY
}

enum TemplateChannel {
  WHATSAPP
  SMS
  EMAIL
}

enum TemplateScope {
  PLATFORM
  BUSINESS
  OUTLET
}

enum TemplateCategory {
  TRANSACTIONAL
  PROMOTIONAL
  UTILITY
  AUTH
}

// Approval workflow:
//   DRAFT             → editable by author
//   PENDING_PLATFORM  → submitted by business/outlet, awaiting platform admin review
//   PENDING_PROVIDER  → platform approved, awaiting provider (Meta/Gupshup/etc.) review
//   APPROVED          → live, usable for sending
//   REJECTED          → rejected by platform or provider, see rejectionReason
enum TemplateApprovalStatus {
  DRAFT
  PENDING_PLATFORM
  PENDING_PROVIDER
  APPROVED
  REJECTED
}

// ─── Platform / Auth ─────────────────────────────────────

model User {
  id           String     @id @default(cuid())
  email        String?    @unique
  // Plaintext phone — kept for one deploy cycle as a safety net while
  // phoneHash-driven lookups are in production. Drop in a follow-up
  // migration once the new path is proven (see docs/hardening-backlog).
  phone        String     @unique
  // Encrypted plaintext (enc:v1:...). Source of truth for display.
  phoneEnc     String?    @db.Text
  // Deterministic HMAC of the normalized phone — unique-indexed so all
  // lookups by phone happen against this column.
  phoneHash    String?    @unique
  name         String
  passwordHash String?
  status       UserStatus @default(ACTIVE)
  avatarUrl    String?

  roleId     String?
  role       Role?     @relation(fields: [roleId], references: [id])
  businessId String?
  business   Business? @relation(fields: [businessId], references: [id])
  outletId   String?
  outlet     Outlet?   @relation(fields: [outletId], references: [id])

  // Who created this staff member — drives visibility in the admin
  // staff lists. OUTLET = exclusive to the outlet, hidden from
  // business-level views. BUSINESS = managed at business level, can
  // be assigned / reassigned to any outlet under the same business.
  // PLATFORM = system staff (rare). NULL on legacy rows is treated
  // as BUSINESS so historical behaviour for pre-cutover staff stays
  // unchanged.
  ownerScope UserOwnerScope?

  customerOrders         Order[]                 @relation("CustomerOrders")
  staffOrders            Order[]                 @relation("StaffOrders")
  customerClusterOrders  ClusterOrder[]          @relation("CustomerClusterOrders")
  customerAlerts         CustomerAlert[]
  sessions               Session[]
  pushSubscriptions      PushSubscription[]
  auditLogs              AuditLog[]
  kitchenStations        KitchenStation[]        @relation("StationWorker")
  serviceStationWorkers  ServiceStationWorker[]
  customerTagAssignments CustomerTagAssignment[] @relation("UserCustomerTagAssignments")
  favorites              Favorite[]
  outletLinks            OutletCustomer[]        @relation("UserOutletLinks")
  responsibilities       UserResponsibility[]
  orderItemReviews       OrderItemReview[]       @relation("ReviewByCustomer")
  reviewReplies          OrderItemReview[]       @relation("ReviewReplyBy")
  couponTargets          CouponCustomer[]        @relation("CouponTargets")
  couponUsages           CouponUsage[]           @relation("CouponUsages")
  rewardAccount          CustomerRewardAccount?  @relation("RewardAccount")
  rewardTransactions     RewardTransaction[]     @relation("RewardTransactions")
  orderStatusChanges     OrderStatusHistory[]    @relation("OrderStatusHistoryActor")
  outletShiftsOpened     OutletShift[]           @relation("OutletShiftOpenedBy")
  outletShiftsClosed     OutletShift[]           @relation("OutletShiftClosedBy")
  cashierShifts          CashierShift[]          @relation("CashierShifts")
  refundsInitiated       Refund[]                @relation("RefundsInitiated")
  refundsApproved        Refund[]                @relation("RefundsApproved")
  splitShares            SplitShare[]            @relation("SplitShareCustomer")
  splitSharesCreated     SplitShare[]            @relation("SplitShareCreatedBy")
  preferredUpiApp        String?
  profileImageUrl        String?                 @db.MediumText
  alertRingtone          String?                 @default("chime")
  alertVolume            Int?                    @default(70)
  mustChangePassword     Boolean                 @default(false)
  preferredLanguage      String?                 @default("en")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("paynpik_users")
}

model Role {
  id          String    @id @default(cuid())
  name        String
  description String?
  isSystem    Boolean   @default(false)
  // Template roles live at platform scope (businessId null) and act as
  // defaults that get cloned into each new business's role of the same name.
  // Edits to a template cascade to every per-business copy.
  isTemplate  Boolean   @default(false)
  businessId  String?
  business    Business? @relation(fields: [businessId], references: [id])
  outletId    String?
  outlet      Outlet?   @relation(fields: [outletId], references: [id])

  responsibilities RoleResponsibility[]
  users            User[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([businessId])
  @@index([outletId])
  @@map("paynpik_roles")
}

model Responsibility {
  id          String  @id @default(cuid())
  name        String  @unique
  description String?
  module      String

  roles RoleResponsibility[]
  users UserResponsibility[]

  @@map("paynpik_responsibilities")
}

model UserResponsibility {
  userId           String
  responsibilityId String
  // true  → grant this permission on top of the user's role
  // false → revoke this permission from the user's role
  granted          Boolean

  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  responsibility Responsibility @relation(fields: [responsibilityId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@id([userId, responsibilityId])
  @@map("paynpik_user_responsibilities")
}

// ─── Internationalisation ─────────────────────────────────
model Language {
  code       String  @id // ISO 639-1, e.g. "en", "hi", "ta"
  name       String // English display name, e.g. "Hindi"
  nativeName String // Native display name, e.g. "हिन्दी"
  isEnabled  Boolean @default(true)

  translations Translation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("paynpik_languages")
}

model Translation {
  entityType   String // e.g. "Item", "Category", "Outlet", "Order.itemSnapshot"
  entityId     String
  fieldName    String // e.g. "name", "description", "address"
  languageCode String
  value        String @db.Text
  source       String @default("auto") // "auto" | "manual"

  language Language @relation(fields: [languageCode], references: [code], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@id([entityType, entityId, fieldName, languageCode])
  @@index([entityType, languageCode])
  @@map("paynpik_translations")
}

model RoleResponsibility {
  roleId           String
  responsibilityId String
  role             Role           @relation(fields: [roleId], references: [id], onDelete: Cascade)
  responsibility   Responsibility @relation(fields: [responsibilityId], references: [id], onDelete: Cascade)

  @@id([roleId, responsibilityId])
  @@map("paynpik_role_responsibilities")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // JWTs comfortably exceed VARCHAR(191). Bump to 500 so MySQL can still
  // index the column (TEXT can't hold a unique index without a prefix).
  token     String   @unique @db.VarChar(500)
  ipAddress String?
  userAgent String?
  expiresAt DateTime

  createdAt DateTime @default(now())

  @@map("paynpik_sessions")
}

// One row per (user, device) so the push fan-out hits every installed
// PWA / Capacitor APK the customer has signed in on. token is the
// FCM registration id for Android; for browser Web Push (added later)
// we'll either reuse this column with kind=WEBPUSH + a separate JSON
// blob for the keys, or add a dedicated WebPushSubscription model.
//
// platform is a free-text tag (`android`, `ios`, `web`) so analytics
// can later answer "what % of our customers are on the APK." The
// composite unique on (userId, token) makes re-registration cheap —
// the same device reuses the same row.
model PushSubscription {
  id       String   @id @default(cuid())
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind     PushKind @default(FCM)
  token    String   @db.VarChar(500)
  platform String?  @db.VarChar(32)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, token])
  @@index([userId])
  @@map("paynpik_push_subscriptions")
}

enum PushKind {
  FCM // Firebase Cloud Messaging (Capacitor Android, iOS, web Chrome via FCM gateway)
  WEBPUSH // VAPID Web Push (browser PWAs that opted out of FCM gateway)
}

model AuditLog {
  id        String  @id @default(cuid())
  userId    String?
  user      User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String
  module    String
  entityId  String?
  oldValue  Json?
  newValue  Json?
  ipAddress String?

  createdAt DateTime @default(now())

  @@map("paynpik_audit_logs")
}

// ─── Business Hierarchy ──────────────────────────────────

model Facility {
  id               String   @id @default(cuid())
  name             String
  address          String
  facilityType     String
  totalSeating     Int?
  operationalHours Json?
  businessId       String
  business         Business @relation(fields: [businessId], references: [id])

  outlets Outlet[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("paynpik_facilities")
}

model Business {
  id              String       @id @default(cuid())
  name            String
  description     String?      @db.VarChar(250)
  address         String?
  addressLine1    String?
  addressLine2    String?
  city            String?
  state           String?
  pincode         String?
  country         String?      @default("India")
  mapsLocation    String?
  gstNumber       String?
  upiId           String?
  businessType    BusinessType
  logoUrl         String?      @db.MediumText
  thumbnailUrl    String?      @db.MediumText
  primaryImageUrl String?      @db.MediumText
  status          UserStatus   @default(ACTIVE)

  // Short, public-shareable identifier (e.g. "BIZ-A4F23C81"). Required for
  // Cluster businesses since they need a QR-resolvable code; backfilled for
  // every business at migration time so the column is uniformly populated.
  publicCode String? @unique @db.VarChar(20)

  // CLUSTER: a Business of category "Cluster" is a logical roof (food court,
  // theatre) that aggregates outlets from other businesses. It owns no outlets
  // of its own — its `outlets` collection stays empty — and instead pulls
  // member outlets in via the ClusterMember join. Customers see all members
  // under one shell with a unified cart and a single payment that the backend
  // splits per outlet (Razorpay Route).
  isCluster Boolean @default(false)

  // When true the business uses multiple menus (e.g. Breakfast / Lunch / Dinner).
  // When false a single hidden "Main Menu" is used and the UI hides menu tabs.
  // Every business has at least one Menu row regardless of the flag.
  multipleMenusEnabled Boolean @default(false)

  subscriptionId String?       @unique
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id])

  // Per-business platform-fee override. Null = inherit from
  // PlatformSettings (the global default). Percentage is applied to
  // the order total; if the result is below `platformFeeMinimum`,
  // the minimum is charged instead. Razorpay Route then receives
  // (total - fee) as the transfer to the outlet's LA.
  platformFeePercent Decimal? @db.Decimal(5, 2)
  platformFeeMinimum Decimal? @db.Decimal(10, 2)

  outlets    Outlet[]
  users      User[]
  roles      Role[]
  facilities Facility[]
  vendors    Vendor[]
  materials  Material[]
  images     BusinessImage[]
  categories Category[]
  menus      Menu[]

  // Cluster relations — only populated when isCluster = true.
  clusterMembers ClusterMember[] @relation("ClusterMembership")
  clusterOrders  ClusterOrder[]  @relation("ClusterOrders")

  messageTemplates MessageTemplate[]

  // Promotions (coupons / discounts / bundles / offers) authored at the
  // business level. Outlet-scope rows live in the corresponding tables too,
  // selected by outletId.
  coupons   Coupon[]
  discounts Discount[]
  offers    Offer[]

  // ── i18n (Phase 3 of perf plan) ──────────────────────────────
  // primaryLanguage = customer-facing default when no preference is
  //   signalled. A Tamil Nadu chain uses 'ta'; defaults to 'en'.
  // eagerLanguages  = JSON string-array of language codes to
  //   pre-translate on every menu/business edit. Everything else
  //   falls to the on-demand lazy path. Typical setting: a primary
  //   regional language + English + one or two core secondaries.
  // Customers can still request any platform-supported language at
  //   any outlet — these knobs only affect provider-cost ergonomics.
  primaryLanguage String? @default("en") @db.VarChar(8)
  eagerLanguages  Json?

  // Denormalised i18n cells — populated by upsertAll alongside the
  // legacy paynpik_translations rows. Shape per cell:
  //   { "hi": "हिंदी value", "ta": "தமிழ் value" }
  // Source-language (English) value stays in the matching plain
  // column; the i18n cell never carries the source itself.
  name_i18n         Json?
  description_i18n  Json?
  address_i18n      Json?
  addressLine1_i18n Json?
  addressLine2_i18n Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("paynpik_businesses")
}

model BusinessImage {
  id           String   @id @default(cuid())
  businessId   String
  business     Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  url          String   @db.MediumText
  displayOrder Int      @default(0)

  createdAt DateTime @default(now())

  @@index([businessId, displayOrder])
  @@map("paynpik_business_images")
}

model Outlet {
  id              String     @id @default(cuid())
  // Short, cryptic, human-shareable identifier (e.g. "OL-A4F23C81"). Used
  // wherever the long CUID would be unwieldy: invoices, support tickets,
  // staff/customer reference. Generated at create time; one per outlet for
  // life. The migration backfills existing rows deterministically from id.
  publicCode      String?    @unique @db.VarChar(20)
  name            String
  outletType      OutletType
  address         String?
  addressLine1    String?
  addressLine2    String?
  city            String?
  state           String?
  pincode         String?
  country         String?    @default("India")
  mapsLocation    String?
  description     String?    @db.VarChar(250)
  phone           String?
  gstNumber       String?
  // FSSAI registration / license number printed on the customer bill
  // (mandatory under FSSAI rules for any business serving food).
  // 14-digit numeric in production but kept as a free-text column so a
  // central kitchen's CKL number or a manufacturing licence shape can
  // also be entered without schema gymnastics.
  fssaiNumber     String?    @db.VarChar(32)
  upiId           String?
  logoUrl         String?    @db.MediumText
  primaryImageUrl String?    @db.MediumText
  isActive        Boolean    @default(true)

  // Outlet-level operations defaults. Parcel is available everywhere by
  // default — the obsolete SELF_SERVICE_PARCEL outlet type has been retired
  // and counter / hybrid outlets all offer parcel out of the box.
  defaultPrepTime     Int?
  parcelChargeEnabled Boolean @default(true)
  defaultParcelCharge Decimal @default(0) @db.Decimal(10, 2)

  // Persistent order sequence (continuous across days). orderNumber on each
  // created order pulls + increments this counter atomically. Token counter is
  // configurable: tokenStartNumber is the value reset() returns to, and
  // nextTokenNumber is the next token to be issued.
  nextOrderSequence Int @default(1)
  tokenStartNumber  Int @default(1)
  nextTokenNumber   Int @default(1)

  // Per-outlet master switch for the multi-menu UI. The business flag
  // (Business.multipleMenusEnabled) controls whether menus can be authored;
  // this flag controls whether customers, staff and outlet admins at this
  // outlet see them. When false, only the default menu's categories are
  // returned by /outlets/:id/menu, regardless of other menus' enable state.
  multipleMenusEnabled Boolean @default(false)

  // GST / tax config
  gstApplicable    Boolean @default(false)
  gstPercent       Decimal @default(0) @db.Decimal(5, 2)
  priceIncludesGst Boolean @default(false)

  // Razorpay Route — the outlet's Razorpay Linked Account (LA) ID. When the
  // outlet is a member of a Cluster, the cluster's payment is split via
  // Razorpay's `transfers` array so funds settle directly to this LA.
  // In stubbed test mode (RAZORPAY_STUB_TRANSFERS=true) the split is computed
  // and persisted on ClusterOrder.routeTransfers, but no real transfer fires.
  razorpayLinkedAccountId String?
  businessId              String
  business                Business  @relation(fields: [businessId], references: [id])
  facilityId              String?
  facility                Facility? @relation(fields: [facilityId], references: [id])

  users                  User[]
  sections               Section[]
  categories             Category[]
  orders                 Order[]
  outletShifts           OutletShift[]
  aggregatorIntegrations AggregatorIntegration[]
  aggregatorCustomers    AggregatorCustomer[]
  tables                 Table[]
  qrCodes                QRCode[]
  kitchenStations        KitchenStation[]
  serviceStations        ServiceStation[]
  customerTags           CustomerTag[]
  customerTagAssignments CustomerTagAssignment[] @relation("OutletCustomerTagAssignments")
  toppings               Topping[]
  images                 OutletImage[]
  hours                  OutletHour[]
  tableTypes             TableType[]
  customerLinks          OutletCustomer[]        @relation("OutletCustomerLinks")
  roles                  Role[]
  menus                  OutletMenu[]
  messageTemplates       MessageTemplate[]

  // 1:1 with ClusterMember (the join row makes outletId unique, so an
  // outlet is in at most one cluster at a time — "cluster-exclusive while
  // linked" semantics).
  clusterMembership ClusterMember? @relation("OutletClusterMembership")

  // Whether this outlet accepts reward-point redemptions at checkout. The
  // earn side is always on (customers earn points everywhere they spend);
  // burn side is a per-outlet business decision.
  acceptRewardRedemption Boolean @default(true)

  // Kitchen-station receipt printing. When `kitchenAutoPrint` is on, each
  // station auto-prints its slice of every confirmed order to the printer
  // assigned to it. When `kitchenAllowManualPrint` is on, station staff can
  // tap a Print button on a ticket to print on demand. Both default off so
  // outlets opt-in explicitly.
  kitchenAutoPrint        Boolean @default(false)
  kitchenAllowManualPrint Boolean @default(false)

  // Customer-receipt printing. Mirrors the kitchen pair above but
  // routes to a single dedicated `receiptPrinterId` (the front-of-
  // house counter printer). receiptAutoPrint fires the bill the
  // moment an order is created/paid; receiptAllowManualPrint exposes
  // a Print Receipt button so staff can reprint on demand or print
  // only when the customer asks. Both default off.
  receiptAutoPrint        Boolean  @default(false)
  receiptAllowManualPrint Boolean  @default(false)
  receiptPrinterId        String?
  receiptPrinter          Printer? @relation("OutletReceiptPrinter", fields: [receiptPrinterId], references: [id], onDelete: SetNull)

  // Per-outlet promotion rows. Business-wide promotions live with
  // outletId = null and apply to every outlet under the business.
  coupons   Coupon[]
  discounts Discount[]
  offers    Offer[]
  printers  Printer[]

  // Split-bill Phase B knobs.
  //   splitReminderEveryMinutes — gap between auto-reminders to a
  //     pending share. Default 60 min.
  //   splitMaxReminders — caps the resend loop so a diner who's
  //     ignoring the message doesn't get spammed indefinitely. Default 3.
  //   splitExpireAfterMinutes — total window from share creation;
  //     once crossed without payment, the share auto-EXPIREs. Default
  //     1440 (24h).
  //   splitFeesAbsorbedBy — who pays the Razorpay convenience fee
  //     when the diner chooses Razorpay. CUSTOMER adds the fee to the
  //     payment-link total + shows a Convenience Fee line on the
  //     BillSharePage breakdown. OUTLET (default) eats the fee.
  splitReminderEveryMinutes Int                @default(60)
  splitMaxReminders         Int                @default(3)
  splitExpireAfterMinutes   Int                @default(1440)
  splitFeesAbsorbedBy       SplitFeeAbsorption @default(OUTLET)

  // Business-admin-controlled feature toggle. When false, the
  // outlet admin doesn't see the Aggregators sub-page under
  // Settings, and inbound webhooks for this outlet keep working
  // only via integrations that were already set up before the flag
  // was flipped (the AggregatorIntegration table is independent of
  // this flag). Default false so the toggle is opt-in per outlet.
  aggregatorEnabled Boolean @default(false)

  // i18n denorm — see Business.* for the shape/lifecycle.
  name_i18n         Json?
  description_i18n  Json?
  address_i18n      Json?
  addressLine1_i18n Json?
  addressLine2_i18n Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("paynpik_outlets")
}

model Section {
  id       String  @id @default(cuid())
  name     String
  isActive Boolean @default(true)
  outletId String
  outlet   Outlet  @relation(fields: [outletId], references: [id])

  tables         Table[]
  orders         Order[]
  // Menus that are explicitly DISABLED in this section. Absent row =
  // menu visible here (default). Used when a customer scans a table QR
  // and we need to hide certain menus only for that physical area
  // (e.g. "Bar menu" hidden in the "Kids' room" section).
  menuExclusions MenuSectionExclusion[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("paynpik_sections")
}

model Table {
  id          String     @id @default(cuid())
  number      String
  capacity    Int        @default(4)
  isActive    Boolean    @default(true)
  sectionId   String?
  section     Section?   @relation(fields: [sectionId], references: [id])
  outletId    String
  outlet      Outlet     @relation(fields: [outletId], references: [id])
  tableTypeId String?
  tableType   TableType? @relation(fields: [tableTypeId], references: [id])

  qrCode              QRCode?
  orders              Order[]
  serviceStationLinks ServiceStationTable[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("paynpik_tables")
}

model QRCode {
  id       String  @id @default(cuid())
  type     QRType
  code     String  @unique
  // Base64 PNG data URL — easily 5-20KB. MediumText (16MB) gives plenty
  // of headroom; older Text (64KB) blew up for high-res phone photos.
  imageUrl String? @db.MediumText
  isActive Boolean @default(true)

  outletId String?
  outlet   Outlet? @relation(fields: [outletId], references: [id])
  tableId  String? @unique
  table    Table?  @relation(fields: [tableId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("paynpik_qr_codes")
}

// ─── Menu ─────────────────────────────────────────────────

model Category {
  id           String  @id @default(cuid())
  name         String
  imageUrl     String? @db.MediumText
  displayOrder Int     @default(0)
  isActive     Boolean @default(true)

  // A category belongs to either an outlet (the outlet's live menu) or a
  // business (a template menu outlets can import). Exactly one of outletId /
  // businessId must be set — enforced in service layer.
  outletId   String?
  outlet     Outlet?   @relation(fields: [outletId], references: [id])
  businessId String?
  business   Business? @relation(fields: [businessId], references: [id])

  // Parent menu. Nullable for legacy categories; the data migration backfills
  // every existing category to its business's default "Main Menu". New
  // categories should always set this. When the business's
  // multipleMenusEnabled flag is OFF the UI hides the menu picker and assigns
  // the default menu transparently.
  menuId String?
  menu   Menu?   @relation(fields: [menuId], references: [id])

  subcategories Subcategory[]
  discounts     Discount[]
  // Offers that target this category as the freebie pool (scope=CATEGORY).
  offerGets     Offer[]              @relation("OfferGetCategory")
  // Optional per-day availability windows. Absent = no constraint at this
  // level; the outlet hours and any parent-level slots still apply
  // (cascading semantics — see menu.service.getMenu).
  timingSlots   CategoryTimingSlot[]

  // i18n denorm — see Business.* for the shape/lifecycle.
  name_i18n Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([outletId])
  @@index([businessId])
  @@index([menuId])
  @@map("paynpik_categories")
}

// Per-day-of-week availability slot at the category level. Same shape as
// MenuTimingSlot (dayOfWeek 1=Mon..7=Sun, minutes-since-midnight 0..1440).
// Multiple rows per day are allowed for split shifts.
model CategoryTimingSlot {
  id          String   @id @default(cuid())
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  dayOfWeek   Int
  startMinute Int
  endMinute   Int

  @@index([categoryId, dayOfWeek])
  @@map("paynpik_category_timing_slots")
}

model Subcategory {
  id           String   @id @default(cuid())
  name         String
  imageUrl     String?  @db.MediumText
  displayOrder Int      @default(0)
  isActive     Boolean  @default(true)
  categoryId   String
  category     Category @relation(fields: [categoryId], references: [id])

  items       Item[]
  discounts   Discount[]
  // Optional per-day availability windows (see CategoryTimingSlot).
  timingSlots SubcategoryTimingSlot[]

  // i18n denorm — see Business.* for the shape/lifecycle.
  name_i18n Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("paynpik_subcategories")
}

model SubcategoryTimingSlot {
  id            String      @id @default(cuid())
  subcategoryId String
  subcategory   Subcategory @relation(fields: [subcategoryId], references: [id], onDelete: Cascade)
  dayOfWeek     Int
  startMinute   Int
  endMinute     Int

  @@index([subcategoryId, dayOfWeek])
  @@map("paynpik_subcategory_timing_slots")
}

// ─── Menus ─────────────────────────────────────────────────────
// A Menu groups a set of Categories under a Business (e.g. Breakfast, Lunch).
// Every business has at least one "Main Menu" (auto-seeded). When the
// business's multipleMenusEnabled flag is OFF, the UI hides tabs and treats
// the single menu as implicit. Outlets opt in to specific menus via OutletMenu.

model Menu {
  id           String   @id @default(cuid())
  businessId   String
  business     Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name         String
  description  String?  @db.VarChar(250)
  isActive     Boolean  @default(true)
  displayOrder Int      @default(0)
  // Marks the auto-seeded default menu so we can prevent deletion. There's
  // always exactly one isDefault=true per business.
  isDefault    Boolean  @default(false)

  timingSlots       MenuTimingSlot[]
  categories        Category[]
  outletLinks       OutletMenu[]
  orderItems        OrderItem[]
  tableTypeLinks    TableTypeMenu[]
  sectionExclusions MenuSectionExclusion[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([businessId, displayOrder])
  @@map("paynpik_menus")
}

// Per-day-of-week availability slot. Multiple slots per day are allowed to
// model split shifts (e.g. Tue 07:00-10:00 + 18:00-22:00). dayOfWeek follows
// ISO: 1=Mon .. 7=Sun. Times are stored as minutes-since-midnight (0..1440)
// so the API can do clean comparisons without timezone parsing.
model MenuTimingSlot {
  id          String @id @default(cuid())
  menuId      String
  menu        Menu   @relation(fields: [menuId], references: [id], onDelete: Cascade)
  dayOfWeek   Int
  startMinute Int
  endMinute   Int

  @@index([menuId, dayOfWeek])
  @@map("paynpik_menu_timing_slots")
}

// Join row: this outlet imports/exposes this menu. Carries the outlet's
// enable toggle and optional timing override (when overrideTimings=true, the
// slots in OutletMenuTimingSlot take precedence; otherwise the business
// Menu.timingSlots apply).
model OutletMenu {
  id              String  @id @default(cuid())
  outletId        String
  outlet          Outlet  @relation(fields: [outletId], references: [id], onDelete: Cascade)
  menuId          String
  menu            Menu    @relation(fields: [menuId], references: [id], onDelete: Cascade)
  isEnabled       Boolean @default(true)
  overrideTimings Boolean @default(false)
  displayOrder    Int     @default(0)

  timingSlots OutletMenuTimingSlot[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([outletId, menuId])
  @@index([outletId, displayOrder])
  @@map("paynpik_outlet_menus")
}

model OutletMenuTimingSlot {
  id           String     @id @default(cuid())
  outletMenuId String
  outletMenu   OutletMenu @relation(fields: [outletMenuId], references: [id], onDelete: Cascade)
  dayOfWeek    Int
  startMinute  Int
  endMinute    Int

  @@index([outletMenuId, dayOfWeek])
  @@map("paynpik_outlet_menu_timing_slots")
}

enum FoodGrade {
  VEG
  NON_VEG
  VEGAN
}

model Item {
  id                    String            @id @default(cuid())
  name                  String
  description           String?
  shortDescription      String?           @db.VarChar(50)
  longDescription       String?           @db.VarChar(250)
  thumbnailUrl          String?           @db.MediumText
  imageUrl              String?           @db.MediumText
  basePrice             Decimal           @db.Decimal(10, 2)
  // Default GST % at item level. Used unless overridden per customer-tag or
  // per table-type (CustomerTagPrice.gstRate / TableTypePrice.gstRate). If
  // null, falls back to outlet's gstPercent.
  gstRate               Decimal?          @db.Decimal(5, 2)
  parcelAvailable       Boolean           @default(true)
  useCustomParcelCharge Boolean           @default(false)
  parcelCharge          Decimal?          @db.Decimal(10, 2)
  preparationTime       Int?
  foodGrade             FoodGrade         @default(VEG)
  isAvailable           Boolean           @default(true)
  isDisplayed           Boolean           @default(true)
  isPopular             Boolean           @default(false)
  isSpecial             Boolean           @default(false)
  // Limited-stock mode: when true, this item tracks `availableQuantity` and is
  // auto-flipped to isAvailable=false once stock hits 0. Outlet staff add stock
  // by incrementing (not replacing) via PATCH /items/:id/stock { addQuantity }.
  // When false, the item is unlimited and the count is ignored.
  hasLimitedStock       Boolean           @default(false)
  availableQuantity     Int               @default(0)
  // How this item is sold. NULL = NUMBER (legacy default — keeps every
  // existing item rendered as a count). GRAMS / MILLILITERS turns the
  // variants list into portion sizes and labels the customer picker
  // with the unit suffix (e.g. "250g").
  quantityUnit          ItemQuantityUnit?
  displayOrder          Int               @default(0)
  subcategoryId         String
  subcategory           Subcategory       @relation(fields: [subcategoryId], references: [id])

  kitchenStationId String?
  kitchenStation   KitchenStation? @relation(fields: [kitchenStationId], references: [id])

  // When true, each OrderItem row for this item prints its own kitchen
  // slip (with the order's token and just that line — variant, toppings,
  // qty, notes) instead of being grouped into the station's combined
  // ticket. Intended for items where toppings / variants make per-line
  // identification critical at hand-off.
  printSeparately Boolean @default(false)

  // When true, this Item is a Bundle — at order time the server expands it
  // into its child rows (see ItemBundleChild). Bundles still live under a
  // subcategory and inherit every Item feature (variants, customer-tag /
  // table-type price overrides, visibility, limited stock, QR, etc.). The
  // only difference is the expansion at order time.
  isBundle            Boolean @default(false)
  // Customer-choice bundles: when set (>0), the customer must pick exactly
  // this many child rows out of the bundleChildren list at order time. Null
  // or 0 = legacy behavior (all children auto-included). Must be ≤ number
  // of configured children; admin form enforces this.
  maxBundleSelections Int?

  variants           Variant[]
  options            Option[]
  orderItems         OrderItem[]
  orderItemsAsBundle OrderItem[]             @relation("BundleParent")
  reviews            OrderItemReview[]
  tags               ItemTag[]
  customerTagPrices  CustomerTagPrice[]
  tableTypePrices    TableTypePrice[]
  images             ItemImage[]
  itemToppings       ItemTopping[]
  favorites          Favorite[]
  discounts          Discount[]
  bundleChildren     ItemBundleChild[]       @relation("BundleParentItem")
  bundleParentLinks  ItemBundleChild[]       @relation("BundleChildItem")
  offerBuyFor        Offer[]                 @relation("OfferBuyItem")
  offerGetFor        Offer[]                 @relation("OfferGetItem")
  // Optional per-day availability windows (see CategoryTimingSlot).
  timingSlots        ItemTimingSlot[]
  // Per-aggregator-channel external id mapping (Zomato/Swiggy/etc).
  aggregatorMappings AggregatorItemMapping[]

  // i18n denorm — see Business.* for the shape/lifecycle.
  name_i18n             Json?
  description_i18n      Json?
  shortDescription_i18n Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("paynpik_items")
}

model ItemTimingSlot {
  id          String @id @default(cuid())
  itemId      String
  item        Item   @relation(fields: [itemId], references: [id], onDelete: Cascade)
  dayOfWeek   Int
  startMinute Int
  endMinute   Int

  @@index([itemId, dayOfWeek])
  @@map("paynpik_item_timing_slots")
}

model ItemImage {
  id           String @id @default(cuid())
  itemId       String
  item         Item   @relation(fields: [itemId], references: [id], onDelete: Cascade)
  url          String @db.MediumText
  displayOrder Int    @default(0)

  createdAt DateTime @default(now())

  @@index([itemId, displayOrder])
  @@map("paynpik_item_images")
}

model Variant {
  id               String  @id @default(cuid())
  name             String
  shortDescription String? @db.VarChar(80)
  price            Decimal @db.Decimal(10, 2)
  isAvailable      Boolean @default(true)
  // Numeric size for portion-based items. Reads in the parent Item's
  // quantityUnit (so 250 + GRAMS = "250g"). Optional — when null the
  // variant is treated as a plain-named variant (Small / Medium / Large).
  unitQuantity     Int?
  itemId           String
  item             Item    @relation(fields: [itemId], references: [id])

  orderItems        OrderItem[]
  customerTagPrices CustomerTagPrice[]
  tableTypePrices   TableTypePrice[]
  bundleChildLinks  ItemBundleChild[]

  // i18n denorm — see Business.* for the shape/lifecycle.
  name_i18n             Json?
  shortDescription_i18n Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("paynpik_variants")
}

model Option {
  id     String  @id @default(cuid())
  name   String
  price  Decimal @default(0) @db.Decimal(10, 2)
  itemId String
  item   Item    @relation(fields: [itemId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("paynpik_options")
}

model ItemTag {
  id     String @id @default(cuid())
  name   String
  itemId String
  item   Item   @relation(fields: [itemId], references: [id])

  @@map("paynpik_item_tags")
}

model KitchenStation {
  id              String  @id @default(cuid())
  name            String
  isActive        Boolean @default(true)
  isMaster        Boolean @default(false)
  outletId        String
  outlet          Outlet  @relation(fields: [outletId], references: [id])
  currentWorkerId String?
  currentWorker   User?   @relation("StationWorker", fields: [currentWorkerId], references: [id], onDelete: SetNull)

  // Optional bluetooth printer this station prints its kitchen tickets to.
  // Multiple stations can point at the same printer (one shared printer in
  // the kitchen is the common case). Null = no printer assigned, so any
  // print action for this station no-ops with a friendly toast.
  printerId String?
  printer   Printer? @relation(fields: [printerId], references: [id], onDelete: SetNull)

  items Item[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("paynpik_kitchen_stations")
}

// Outlet-level catalog of printers (bluetooth-connected receipt printers in
// the kitchen). Stations bind to a printer via KitchenStation.printerId; one
// printer can serve many stations. Actual printing happens client-side via
// the Web Bluetooth API — the address/identifier is stored so the kitchen
// PWA knows which device to connect to.
model Printer {
  id       String @id @default(cuid())
  outletId String
  outlet   Outlet @relation(fields: [outletId], references: [id], onDelete: Cascade)
  name     String

  // Inverse of Outlet.receiptPrinter — at most one outlet picks this
  // printer as its receipt target. Deleting the printer resets that
  // outlet's receiptPrinterId to null via the relation's ON DELETE SET NULL.
  receiptForOutlets Outlet[] @relation("OutletReceiptPrinter")
  // Connection type. Today only 'BLUETOOTH'; kept as a string column so we
  // can add wifi/USB later without an enum migration.
  connection        String   @default("BLUETOOTH") @db.VarChar(20)
  // Device identifier — bluetooth MAC or Web-Bluetooth `deviceId`. Free-form
  // because the value is platform-dependent (Web Bluetooth returns an opaque
  // id, native bridges expose a MAC).
  address           String?  @db.VarChar(128)
  // Optional printer model/notes for the admin's reference.
  model             String?
  isActive          Boolean  @default(true)

  stations KitchenStation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([outletId])
  @@map("paynpik_printers")
}

// Conditional freebies: "spend ₹500 get a complementary sweet" or
// "buy 3 beers get 1 free at happy-hour". Distinct from Coupon (customer-
// selected at checkout) and Discount (price reduction on items/categories).
// Offers auto-trigger when a cart meets the rule and add a ₹0-priced line.
model Offer {
  id          String  @id @default(cuid())
  name        String
  description String?

  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  outletId   String?
  outlet     Outlet?  @relation(fields: [outletId], references: [id], onDelete: Cascade)

  // MIN_BILL: free item when cart subtotal >= minBillAmount
  // BUY_X_GET_Y: free `getQuantity` of `getItem` when cart has
  //   `buyQuantity` of `buyItem`
  triggerType   String   @db.VarChar(20)
  minBillAmount Decimal? @db.Decimal(10, 2)

  buyItemId    String?
  buyItem      Item?   @relation("OfferBuyItem", fields: [buyItemId], references: [id])
  buyVariantId String?
  buyQuantity  Int?

  // Legacy single-item path — set with getScope=null. Kept for
  // back-compat; new offers should prefer the multi-option fields below.
  getItemId    String?
  getItem      Item?   @relation("OfferGetItem", fields: [getItemId], references: [id])
  getVariantId String?
  getQuantity  Int?

  // Multi-option freebie pool. The admin picks how the customer can
  // choose their freebies:
  //   ALL      → every active outlet item is eligible
  //   CATEGORY → only items inside getCategoryId qualify
  //   ITEMS    → only items whose id is in getItemIds[] qualify
  //   null     → legacy single-item path (uses getItemId above)
  // The customer then picks `getQuantity` items from the eligible pool
  // (duplicates allowed) at checkout.
  getScope      String?   @db.VarChar(10)
  getCategoryId String?
  getCategory   Category? @relation("OfferGetCategory", fields: [getCategoryId], references: [id])
  getItemIds    Json?

  // Schedule
  validFrom   DateTime?
  validUntil  DateTime?
  daysOfWeek  String?   @db.VarChar(20) // CSV, ISO 1=Mon..7=Sun ("1,2,3,4,5")
  startMinute Int? // minutes-since-midnight
  endMinute   Int?

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([businessId])
  @@index([outletId])
  @@index([isActive])
  @@map("paynpik_offers")
}

// ─── Orders ──────────────────────────────────────────────

model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique
  tokenNumber     Int?
  status          OrderStatus @default(CREATED)
  isParcel        Boolean     @default(false)
  // True for Dine-in Postpaid orders: created without payment, accepts
  // additional items until `billRequestedAt` is set (Bill Now). Once set,
  // the order is locked and the Cash/UPI payment flow takes over.
  isPostpaid      Boolean     @default(false)
  billRequestedAt DateTime?
  notes           String?

  subtotal       Decimal @db.Decimal(10, 2)
  taxAmount      Decimal @default(0) @db.Decimal(10, 2)
  // SGST + CGST always sum to taxAmount; stored explicitly for cleaner
  // reporting / invoice display. For intra-state Indian GST they're 50/50.
  sgstAmount     Decimal @default(0) @db.Decimal(10, 2)
  cgstAmount     Decimal @default(0) @db.Decimal(10, 2)
  parcelAmount   Decimal @default(0) @db.Decimal(10, 2)
  discountAmount Decimal @default(0) @db.Decimal(10, 2)
  totalAmount    Decimal @db.Decimal(10, 2)

  outletId   String
  outlet     Outlet   @relation(fields: [outletId], references: [id])
  sectionId  String?
  section    Section? @relation(fields: [sectionId], references: [id])
  tableId    String?
  table      Table?   @relation(fields: [tableId], references: [id])
  customerId String?
  customer   User?    @relation("CustomerOrders", fields: [customerId], references: [id])
  staffId    String?
  staff      User?    @relation("StaffOrders", fields: [staffId], references: [id])

  // Cashier shift this order was opened against. Nullable for legacy
  // orders + orders placed when no cashier shift was active. Z report
  // counts gross-sales by this column; revenue (payments) is tracked
  // separately via Payment.cashierShiftId since an order placed in one
  // shift can be paid in another (postpaid tabs spanning shift change).
  cashierShiftId String?
  cashierShift   CashierShift? @relation(fields: [cashierShiftId], references: [id])

  // Channel the order came in through. DIRECT covers walk-in / QR /
  // customer PWA. ZOMATO / SWIGGY / UBER_EATS mark inbound marketplace
  // orders so reports can split revenue by channel and the kitchen
  // display can call out where the order originated. The
  // AggregatorOrder side-table holds the external IDs + raw payload.
  channel         AggregatorChannel @default(DIRECT)
  aggregatorOrder AggregatorOrder?

  // Split-bill denormalised counters. Updated inside the same
  // transaction as SplitShare row mutations so the OrdersPage detail
  // and the customer PWA progress pill never need a sub-query to
  // know "3 of 4 paid".  Zero when the order isn't split-billed.
  splitTotalShares Int          @default(0)
  splitPaidShares  Int          @default(0)
  splitPaidAmount  Decimal      @default(0) @db.Decimal(10, 2)
  splitShares      SplitShare[]

  // When non-null, this Order is a child of a ClusterOrder — created as part
  // of a cluster checkout where the customer placed one cart with items from
  // multiple outlets. The parent ClusterOrder holds the unified payment;
  // each child Order is what the outlet's kitchen sees and serves.
  clusterOrderId String?
  clusterOrder   ClusterOrder? @relation("ClusterChildren", fields: [clusterOrderId], references: [id])

  // Course sequencing (optional). Customer/staff can group items into
  // sequential courses ("Starter", "Main", "Dessert"). `activeSequence`
  // tracks which course is currently released to the kitchen. Items with
  // a higher sequenceNumber are held until prior courses are SERVED, at
  // which point activeSequence auto-advances. `sequenceLabels` stores the
  // display name per course as JSON, e.g. {"1":"Starter","2":"Main"}.
  // Items with sequenceNumber=null are always active (default behaviour).
  activeSequence Int   @default(1)
  sequenceLabels Json?

  // Frozen outlet header for the receipt — captured at order creation so
  // a historical bill always prints the address / GSTIN / FSSAI / phone
  // the outlet had at the time, even after the outlet moves or updates
  // its compliance numbers. Shape mirrors the receipt's outlet block:
  // { name, addressLine1, addressLine2, city, state, pincode, gstNumber,
  //   fssaiNumber, phone, logoUrl }. Nullable for legacy rows — the
  //   receipt falls back to the live outlet relation when missing.
  outletSnapshot Json?

  items          OrderItem[]
  payments       Payment[]
  refunds        Refund[]
  statusHistory  OrderStatusHistory[]
  disputes       Dispute[]
  customerAlerts CustomerAlert[]
  couponUsages   CouponUsage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Hot-path composites (added 2026-06-22, Phase 1 of perf plan):
  //   • (outletId, createdAt) — every orders-list view filters by outlet
  //     and sorts by createdAt DESC. The single-column outletId FK index
  //     forces a filesort over thousands of rows on each render.
  //   • (outletId, status, createdAt) — service desk + kitchen station
  //     queries filter by outlet + status IN (...) and want the same
  //     newest-first sort. Lets the optimiser walk the index in order.
  //   • (status) — z-reports and global queues filter on status alone.
  // Single-column outletId/customerId/tableId etc. stay as the implicit
  // FK indexes Prisma generates; these only add the composite + the
  // bare status lookup.
  @@index([outletId, createdAt], map: "idx_orders_outlet_created")
  @@index([outletId, status, createdAt], map: "idx_orders_outlet_status_created")
  @@index([status], map: "idx_orders_status")
  @@map("paynpik_orders")
}

// ─── Cluster (food court / theatre roof) ─────────────────

// Join row linking a member outlet to the cluster (host) business. The
// outletId is UNIQUE so an outlet can be in at most one cluster at any time
// — the "cluster-exclusive while linked" rule. Removing this row releases
// the outlet back to standalone operation.
// Platform-wide settings, kept as a singleton row (id = "singleton").
// Currently holds the default Razorpay platform-fee schedule that's
// applied when a Business doesn't override it. New fields land here so
// admins can edit them through the UI instead of redeploying with new
// env vars.
model PlatformSettings {
  id                 String  @id @default("singleton")
  // Default fee % applied to the order total on every Razorpay Route
  // payment. 0 = no fee (outlet receives the full ticket). Per-business
  // overrides on Business take precedence when set.
  platformFeePercent Decimal @default(0) @db.Decimal(5, 2)
  // Minimum fee in INR. If percent × total falls below this floor, the
  // floor is charged instead.
  platformFeeMinimum Decimal @default(0) @db.Decimal(10, 2)

  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@map("paynpik_platform_settings")
}

// Section-level menu disables. A row here means: this menu is NOT
// available when ordering from this section. Empty default = menu
// visible everywhere. Used by the customer menu fetch when a table
// QR is scanned (server resolves table → section → exclusions).
model MenuSectionExclusion {
  menuId    String
  sectionId String
  menu      Menu     @relation(fields: [menuId], references: [id], onDelete: Cascade)
  section   Section  @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([menuId, sectionId])
  @@index([sectionId])
  @@map("paynpik_menu_section_exclusions")
}

model ClusterMember {
  id                String   @id @default(cuid())
  clusterBusinessId String
  clusterBusiness   Business @relation("ClusterMembership", fields: [clusterBusinessId], references: [id], onDelete: Cascade)
  outletId          String   @unique
  outlet            Outlet   @relation("OutletClusterMembership", fields: [outletId], references: [id])
  displayOrder      Int      @default(0)
  joinedAt          DateTime @default(now())

  @@index([clusterBusinessId, displayOrder])
  @@map("paynpik_cluster_members")
}

// Parent record for a single customer checkout that spans multiple outlets in
// a cluster. The customer's payment lands here; child Orders (one per outlet)
// inherit clusterOrderId and surface independently to each outlet's kitchen.
// routeTransfers is a JSON array — one entry per child order with the
// computed split { outletId, orderId, amount, razorpayLinkedAccountId,
// transferId?, status }. In stubbed test mode the transfer is recorded but
// not actually executed against Razorpay.
model ClusterOrder {
  id                 String   @id @default(cuid())
  clusterOrderNumber String   @unique
  clusterBusinessId  String
  clusterBusiness    Business @relation("ClusterOrders", fields: [clusterBusinessId], references: [id])
  customerId         String?
  customer           User?    @relation("CustomerClusterOrders", fields: [customerId], references: [id])
  // The cluster's shared seating table, if the customer scanned a table QR.
  // Stored as plain string rather than FK because cluster tables may belong
  // to any member outlet — the child Order keeps the canonical FK.
  tableId            String?

  subtotal     Decimal @db.Decimal(10, 2)
  taxAmount    Decimal @default(0) @db.Decimal(10, 2)
  parcelAmount Decimal @default(0) @db.Decimal(10, 2)
  totalAmount  Decimal @db.Decimal(10, 2)

  // 'RAZORPAY' (real gateway) or 'BYPASS' (testing). Kept as a free-form
  // string rather than extending the hot PaymentMode enum used by the
  // single-outlet Payment model.
  paymentMethod     String?       @db.VarChar(20)
  paymentStatus     PaymentStatus @default(PENDING)
  razorpayOrderId   String?
  razorpayPaymentId String?
  razorpaySignature String?       @db.Text
  routeTransfers    Json          @default("[]")

  childOrders Order[] @relation("ClusterChildren")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clusterBusinessId])
  @@index([customerId])
  @@map("paynpik_cluster_orders")
}

model OrderItem {
  id                  String          @id @default(cuid())
  quantity            Int
  unitPrice           Decimal         @db.Decimal(10, 2)
  totalPrice          Decimal         @db.Decimal(10, 2)
  // Resolved GST % captured at order time (sticky against future config changes).
  gstRate             Decimal         @default(0) @db.Decimal(5, 2)
  gstAmount           Decimal         @default(0) @db.Decimal(10, 2)
  notes               String?
  status              OrderItemStatus @default(PENDING)
  // Frozen labels — snapshotted at order-creation time so a historical
  // receipt prints the name the customer actually ordered, even if the
  // Item / Variant has since been renamed or deleted. The Prisma
  // relations are kept so the kitchen + admin views can still link
  // through to live menu state. Nullable for legacy rows.
  itemNameSnapshot    String?         @db.VarChar(255)
  variantNameSnapshot String?         @db.VarChar(255)
  orderId             String
  order               Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  itemId              String
  item                Item            @relation(fields: [itemId], references: [id])
  variantId           String?
  variant             Variant?        @relation(fields: [variantId], references: [id])

  // Menu snapshot — resolved at order-time via item->subcategory->category.menuId.
  // Frozen even if the category later moves to a different menu, so historical
  // receipts keep their original grouping. Nullable for legacy rows.
  menuId String?
  menu   Menu?   @relation(fields: [menuId], references: [id])

  // When the customer ordered a Bundle (an Item flagged isBundle=true), the
  // row was created by expanding the bundle into its child items — all
  // child rows share the same bundleId (= the parent Item.id) so the
  // kitchen ticket + receipt can group them under the bundle's name. Only
  // the first child carries the bundle's price; siblings have totalPrice=0.
  bundleId     String?
  bundleParent Item?   @relation("BundleParent", fields: [bundleId], references: [id])

  // Course position (1-based). Null = no sequencing applied — the item is
  // always live. See Order.activeSequence for the gating rule.
  sequenceNumber Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  review OrderItemReview?

  @@index([menuId])
  @@index([bundleId])
  // Phase 1 perf composites:
  //   • (orderId, status, itemId) — the menu popularity GROUP BY scans
  //     order_items per order and filters by status; the kitchen feed
  //     does the same shape. Lets join + filter + group-key reads stay
  //     index-only.
  //   • (status) — service-desk / kitchen status filters that aren't
  //     scoped by orderId.
  @@index([orderId, status, itemId], map: "idx_orderitems_order_status_item")
  @@index([status], map: "idx_orderitems_status")
  @@map("paynpik_order_items")
}

// ─── Reviews ───────────────────────────────────────────────────
// Per-OrderItem customer rating (1-5) + optional comment. itemId is
// denormalized so the menu can compute aggregates without joining through
// Order. Owner reply + payback fields are added in Phase B.
model OrderItemReview {
  id          String    @id @default(cuid())
  orderItemId String    @unique
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  itemId      String
  item        Item      @relation(fields: [itemId], references: [id])
  customerId  String
  customer    User      @relation("ReviewByCustomer", fields: [customerId], references: [id])
  rating      Int
  comment     String?   @db.Text

  // Owner/manager response. Reply is optional; once set, repliedAt is too.
  replyText     String?   @db.Text
  replyByUserId String?
  replyBy       User?     @relation("ReviewReplyBy", fields: [replyByUserId], references: [id])
  repliedAt     DateTime?

  // Payback: links to a Payment row marked isRefund=true. paybackAmount is
  // duplicated for fast reads; the Payment row is the source of truth.
  paybackAmount    Decimal? @db.Decimal(10, 2)
  paybackPaymentId String?  @unique
  paybackPayment   Payment? @relation(fields: [paybackPaymentId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([itemId])
  @@index([customerId])
  @@map("paynpik_order_item_reviews")
}

model OrderStatusHistory {
  id            String      @id @default(cuid())
  status        OrderStatus
  // Free-text user id of the staff (or null for system rollups). Real
  // FK is on the relation below — keep the field nullable + SET NULL
  // so deleting a staff user doesn't break the audit trail.
  changedBy     String?
  changedByUser User?       @relation("OrderStatusHistoryActor", fields: [changedBy], references: [id], onDelete: SetNull)
  notes         String?
  orderId       String
  order         Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([changedBy])
  @@map("paynpik_order_status_history")
}

model Payment {
  id              String        @id @default(cuid())
  amount          Decimal       @db.Decimal(10, 2)
  mode            PaymentMode
  status          PaymentStatus @default(PENDING)
  // Record-only refund: when an outlet records a payback against a customer
  // review, we mint a Payment with isRefund=true and link it from the review.
  // The mode (CASH/UPI/...) still records how the money was actually returned.
  isRefund        Boolean       @default(false)
  gatewayRef      String?
  gatewayResponse Json?
  orderId         String
  order           Order         @relation(fields: [orderId], references: [id])

  // Cashier shift this payment was recorded against. Stamped at
  // payment-confirmation time on the active cashier shift of the
  // staff confirming the payment. The Z report's cash totals and
  // payment-mode split read this column — not the Order's shift —
  // so a tab opened in one shift and billed in the next attributes
  // revenue to the closing shift correctly.
  cashierShiftId String?
  cashierShift   CashierShift? @relation(fields: [cashierShiftId], references: [id])

  reviewPayback OrderItemReview?
  refunds       Refund[]         @relation("RefundFromPayment")

  // When this Payment settles a split-bill share, the share row points
  // back here via SplitShare.paymentId and we mirror the link here so
  // reports can group payments by share without a reverse join.
  splitShareId String?     @unique
  splitShare   SplitShare? @relation(fields: [splitShareId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([cashierShiftId, status])
  @@map("paynpik_payments")
}

// ─── Cashier shifts / end-of-day Z reports ────────────────
//
// An OutletShift is the per-outlet envelope ("today's session"). A
// new one is opened by an outlet admin (or auto-spawned when a
// cashier first opens their drawer if no envelope exists). Closing
// the envelope rolls up totals across every cashier shift inside it.
//
// CashierShifts are per-cashier drawers under an OutletShift. Each
// has its own opening float, declared closing cash, expected cash
// (derived from CASH payments stamped against it), and variance.
// Z reports can be generated at either level — the cashier level
// is what the cashier closes their drawer with; the outlet level is
// what the manager / accountant reads at end of day.
model OutletShift {
  id             String            @id @default(cuid())
  outletId       String
  outlet         Outlet            @relation(fields: [outletId], references: [id])
  openedAt       DateTime          @default(now())
  closedAt       DateTime?
  // Note string for the operator opening the shift (e.g. "morning")
  // and an optional close note (variance reason etc.). Free-text.
  openNote       String?
  closeNote      String?
  openedByUserId String
  openedBy       User              @relation("OutletShiftOpenedBy", fields: [openedByUserId], references: [id])
  closedByUserId String?
  closedBy       User?             @relation("OutletShiftClosedBy", fields: [closedByUserId], references: [id])
  status         OutletShiftStatus @default(ACTIVE)
  cashierShifts  CashierShift[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([outletId, status])
  @@map("paynpik_outlet_shifts")
}

model CashierShift {
  id            String             @id @default(cuid())
  outletShiftId String
  outletShift   OutletShift        @relation(fields: [outletShiftId], references: [id])
  // Denormalised so the most common Z-report queries
  // (outlet/cashier/date scope) can avoid the join.
  outletId      String
  cashierId     String
  cashier       User               @relation("CashierShifts", fields: [cashierId], references: [id])
  openedAt      DateTime           @default(now())
  closedAt      DateTime?
  // Opening cash float the cashier started with. Required at open
  // — even if zero, the operator declares it explicitly.
  openingFloat  Decimal            @default(0) @db.Decimal(10, 2)
  // Set at close: what the cashier physically counted in the drawer.
  declaredCash  Decimal?           @db.Decimal(10, 2)
  // Set at close: opening + cash payments - cash refunds across the
  // shift. The cashier's drawer should hold exactly this much; any
  // difference between declaredCash and expectedCash is the variance.
  expectedCash  Decimal?           @db.Decimal(10, 2)
  variance      Decimal?           @db.Decimal(10, 2)
  status        CashierShiftStatus @default(ACTIVE)
  openNote      String?
  closeNote     String?

  orders   Order[]
  payments Payment[]
  refunds  Refund[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([cashierId, status])
  @@index([outletShiftId])
  @@map("paynpik_cashier_shifts")
}

// ─── Refunds ──────────────────────────────────────────────
//
// The Refund record tracks the workflow (initiate → approve →
// complete) and serves as the audit trail. When a refund COMPLETES,
// a sibling Payment row with isRefund=true is created — that's what
// the Z report's "Refunds issued" block and the cashier drawer
// reconciliation read. Cash refunds out of the drawer decrement
// expectedCash; gateway refunds (via Razorpay) are settlement-side
// only and don't affect the drawer.
//
// Partial refunds keep the order at FOR_REFUND; only a refund whose
// cumulative refunded amount equals the order's totalAmount flips
// the order to REFUND_COMPLETE.
model Refund {
  id              String        @id @default(cuid())
  orderId         String
  order           Order         @relation(fields: [orderId], references: [id])
  // Source payment this refund is drawn against. Required for gateway
  // refunds (Razorpay needs the original payment_id); for cash-out
  // refunds against a cash-paid order it's also recorded so reports
  // can trace each refund back to a specific receipt.
  paymentId       String?
  payment         Payment?      @relation("RefundFromPayment", fields: [paymentId], references: [id])
  amount          Decimal       @db.Decimal(10, 2)
  // How the money is going back to the customer. Cash refunds are
  // resolved at the cashier's drawer; UPI/CARD/WALLET/NET_BANKING go
  // through Razorpay's refund API.
  mode            PaymentMode
  reason          String?
  status          RefundStatus  @default(INITIATED)
  // Razorpay refund id when gateway-processed. Encrypted at rest the
  // same way Payment.gatewayRef is, to keep parity with how PSP refs
  // are handled elsewhere.
  gatewayRef      String?       @db.Text
  gatewayResponse Json?
  initiatedById   String
  initiatedBy     User          @relation("RefundsInitiated", fields: [initiatedById], references: [id])
  approvedById    String?
  approvedBy      User?         @relation("RefundsApproved", fields: [approvedById], references: [id])
  // Cashier drawer this refund was settled against (set at
  // completion time for cash refunds so drawer reconciliation is
  // correct). Null for gateway refunds.
  cashierShiftId  String?
  cashierShift    CashierShift? @relation(fields: [cashierShiftId], references: [id])
  // Internal notes — failure messages, approver comments.
  notes           String?
  createdAt       DateTime      @default(now())
  approvedAt      DateTime?
  completedAt     DateTime?
  updatedAt       DateTime      @updatedAt

  @@index([orderId])
  @@index([status])
  @@index([cashierShiftId])
  @@map("paynpik_refunds")
}

// ─── Split bill shares ────────────────────────────────────
//
// Each row is one diner's sub-bill against a parent Order. The
// operator creates N shares from the OrdersPage split modal; WhatsApp
// fires to each phone; the diner taps the deep link, lands on the
// customer PWA's bill detail, and pays through the existing payment
// page (UPI or Razorpay) — same flow they'd use for any direct
// order. We don't model a "primary" share — the operator chases via
// the per-share Resend / Cancel / Mark cash buttons on the order
// detail.
//
// On payment, Payment.splitShareId points at this row and the parent
// Order's denormalised splitPaidShares / splitPaidAmount counters
// bump inside the same transaction. Refunds against a share use the
// existing Refund flow against the Payment row — no SplitShare-aware
// changes needed.
model SplitShare {
  id             String           @id @default(cuid())
  orderId        String
  order          Order            @relation(fields: [orderId], references: [id])
  // Share amount in rupees. The sum of all non-CANCELLED shares
  // should equal Order.totalAmount for a fully-split bill; the
  // operator can underallocate (and pay the rest as cash directly
  // on the order) but never overallocate — server validates on
  // create.
  amount         Decimal          @db.Decimal(10, 2)
  // Diner identity. Phone is required (it's the delivery channel for
  // the WhatsApp message); name is optional. customerId is null
  // until the diner taps the WhatsApp link and the auth/OTP flow
  // resolves them to a real User row — at which point the existing
  // phone-hash lookup finds (or creates) the User.
  customerPhone  String
  customerName   String?
  customerId     String?
  customer       User?            @relation("SplitShareCustomer", fields: [customerId], references: [id])
  status         SplitShareStatus @default(PENDING)
  // Settlement link. Populated when the diner pays through the
  // customer PWA's standard payment page, OR when the operator
  // clicks "Mark cash" on the per-share action.
  paymentId      String?          @unique
  payment        Payment?         @relation
  // Operator who created the share — recorded for the order log so
  // staff can trace which cashier filed the split.
  createdById    String
  createdBy      User             @relation("SplitShareCreatedBy", fields: [createdById], references: [id])
  // Lifecycle timestamps for the customer-facing progress display
  // and the Phase-B reminders job.
  sentAt         DateTime?
  viewedAt       DateTime?
  paidAt         DateTime?
  cancelledAt    DateTime?
  // Free-text notes — used today to record "marked cash by operator
  // on shift X" so the audit trail explains why a share didn't
  // settle through the gateway.
  notes          String?
  // Phase B fields. remindersSent caps the auto-resend job; once it
  // hits the outlet's splitMaxReminders the share is left alone.
  // lastReminderAt is the throttle anchor — the job only sends the
  // next reminder when (now - lastReminderAt) >= splitReminderEvery.
  // expiresAt is computed at create-time from outlet.splitExpireAfter;
  // when crossed without a payment, the share auto-flips to EXPIRED.
  remindersSent  Int              @default(0)
  lastReminderAt DateTime?
  expiresAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orderId])
  @@index([customerPhone])
  @@index([customerId])
  @@index([status])
  @@map("paynpik_split_shares")
}

// ─── Aggregator integrations (Zomato / Swiggy / Uber Eats) ────────
//
// The three records below form the framework for inbound + outbound
// aggregator support. Per outlet, an AggregatorIntegration row holds
// the credentials (encrypted JSON) and the per-channel restaurant id
// the aggregator assigns. AggregatorOrder maps an inbound order to
// our Order record + holds the raw payload for audit. AggregatorItemMapping
// maps our Item ids to the per-channel external ids so menu sync /
// item availability toggles can target the right marketplace row.
//
// The actual API calls are implemented per adapter under
// src/modules/aggregators/adapters; until credentials are configured,
// the adapters log + no-op (safe to ship without breaking the
// existing direct-channel flow).
model AggregatorIntegration {
  id                   String            @id @default(cuid())
  outletId             String
  outlet               Outlet            @relation(fields: [outletId], references: [id])
  channel              AggregatorChannel
  isActive             Boolean           @default(false)
  // Encrypted credentials JSON — shape varies per provider
  // (e.g. Zomato: api_key + restaurant_id; Swiggy: similar with menu_id;
  // UberEats: client_id + client_secret + store_id).
  credentialsEnc       String?           @db.Text
  // Per-channel restaurant identifier, surfaced separately for UI
  // convenience (the operator pastes this from the aggregator dashboard).
  externalRestaurantId String?
  // HMAC secret used to validate inbound webhook signatures.
  // Stored encrypted; the channel-specific adapter re-encrypts/decrypts.
  webhookSecretEnc     String?           @db.Text
  // Last successful menu sync to this channel. Drives the "sync menu"
  // pill on the integrations page so operators see when it last ran.
  lastMenuSyncAt       DateTime?
  notes                String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([outletId, channel])
  @@index([channel, isActive])
  @@map("paynpik_aggregator_integrations")
}

model AggregatorOrder {
  id              String                @id @default(cuid())
  // One-to-one with Order; the inbound webhook creates both rows in
  // the same transaction. Use the @unique to enforce this at the DB.
  orderId         String                @unique
  order           Order                 @relation(fields: [orderId], references: [id])
  channel         AggregatorChannel
  // The aggregator's order id (Zomato's order_id, Swiggy's order_id,
  // Uber's order.id). Per-channel-unique with the @@unique below.
  externalOrderId String
  // Last status we pushed back to the aggregator. The adapter's
  // syncStatus is idempotent — re-firing this with the same value is
  // a no-op on the provider side.
  status          AggregatorOrderStatus @default(RECEIVED)
  // Raw inbound payload (encrypted at rest? No — these are inbound
  // marketplace payloads, not customer PII). Used for audit + replay
  // when an adapter changes shape.
  rawPayload      Json?
  // Last sync attempt response — error message for failures so the
  // operator can see why a status push didn't land.
  lastSyncError   String?               @db.Text

  // Marketplace customer link. Nullable because the aggregator may
  // not expose a stable customer id on every payload, and historical
  // rows from before this column existed have no link. The Order's
  // own customerId stays null for aggregator orders — we don't
  // pollute the User table with synthetic rows for masked phones.
  aggregatorCustomerId String?
  aggregatorCustomer   AggregatorCustomer? @relation(fields: [aggregatorCustomerId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([channel, externalOrderId])
  @@index([channel, status])
  @@index([aggregatorCustomerId])
  @@map("paynpik_aggregator_orders")
}

// Per-marketplace customer record. Separate from User because:
//   • Aggregators mask phone numbers, so we can't reliably join to
//     User by phone — the same real person ordering on Zomato vs
//     direct gives us two different "phones" that we shouldn't
//     auto-merge.
//   • The aggregator's stable customer_id (when exposed by the
//     provider) is a far better identity anchor than the masked phone.
//   • Reports + the recognition pill on OrdersPage need a clean way
//     to say "Repeat Swiggy customer · 5th order" without polluting
//     direct-customer counts.
//
// Scoped per-outlet so the recognition counters stay local to where
// the customer actually orders. A chain with one Swiggy customer
// across three outlets gets three rows, which is what we want for
// per-location loyalty/recognition.
model AggregatorCustomer {
  id                 String            @id @default(cuid())
  outletId           String
  outlet             Outlet            @relation(fields: [outletId], references: [id])
  channel            AggregatorChannel
  // The aggregator's stable per-customer identifier. Falls back to
  // the masked phone when the provider doesn't expose this (rare but
  // possible). The @@unique below uses outletId+channel+this so the
  // upsert path can land on a stable row.
  externalCustomerId String
  displayName        String?
  // Aggregator-proxied phone — typically a number that connects to
  // the real customer via the aggregator's call-masking service.
  // Stored for the packing slip and the rider-callback flow.
  maskedPhone        String?
  // Denormalised aggregates so the recognition pill can render
  // without a follow-up COUNT/MAX query per order.
  firstOrderAt       DateTime          @default(now())
  lastOrderAt        DateTime          @default(now())
  orderCount         Int               @default(0)

  orders AggregatorOrder[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // map: explicitly shortens the index names so MySQL's 64-char
  // identifier limit doesn't reject them. The default Prisma-generated
  // names (paynpik_aggregator_customers_outletId_channel_externalCustomerId_key)
  // were 68 chars and tripped ERROR 1059 on the first deploy attempt.
  @@unique([outletId, channel, externalCustomerId], map: "paynpik_agg_cust_outlet_chan_ext_key")
  @@index([channel, externalCustomerId], map: "paynpik_agg_cust_channel_ext_idx")
  @@map("paynpik_aggregator_customers")
}

model AggregatorItemMapping {
  id             String            @id @default(cuid())
  itemId         String
  item           Item              @relation(fields: [itemId], references: [id])
  channel        AggregatorChannel
  // The aggregator's per-item identifier — populated from the menu
  // sync response or pasted in from the aggregator dashboard.
  externalItemId String
  // Optional channel-specific price override. When set, the menu
  // sync pushes this instead of Item.basePrice (aggregator commission
  // structures often require a bumped price on the marketplace side).
  externalPrice  Decimal?          @db.Decimal(10, 2)
  // When false the item is hidden on this channel even if isAvailable
  // is true. Lets staff stop accepting marketplace orders for a dish
  // without affecting the dine-in menu.
  isEnabled      Boolean           @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([itemId, channel])
  @@index([channel, externalItemId])
  @@map("paynpik_aggregator_item_mappings")
}

model Dispute {
  id          String   @id @default(cuid())
  description String
  claimAmount Decimal? @db.Decimal(10, 2)
  status      String   @default("OPEN")
  resolution  String?
  // Stored as Json (array of URL strings) since MySQL lacks native array types.
  attachments Json     @default("[]")
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id])

  // i18n denorm — see Business.* for the shape/lifecycle.
  description_i18n Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("paynpik_disputes")
}

// ─── Inventory ───────────────────────────────────────────

model MaterialCategory {
  id         String             @id @default(cuid())
  name       String
  businessId String
  parentId   String?
  parent     MaterialCategory?  @relation("CategoryTree", fields: [parentId], references: [id])
  children   MaterialCategory[] @relation("CategoryTree")
  materials  Material[]

  @@map("paynpik_material_categories")
}

model Material {
  id           String            @id @default(cuid())
  name         String
  unit         String
  currentStock Decimal           @default(0) @db.Decimal(10, 3)
  reorderLevel Decimal?          @db.Decimal(10, 3)
  costPerUnit  Decimal?          @db.Decimal(10, 2)
  businessId   String
  business     Business          @relation(fields: [businessId], references: [id])
  categoryId   String?
  category     MaterialCategory? @relation(fields: [categoryId], references: [id])

  purchaseOrders PurchaseOrder[]
  consumptions   ConsumptionLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("paynpik_materials")
}

model Vendor {
  id         String   @id @default(cuid())
  name       String
  gstNumber  String?
  phone      String?
  email      String?
  address    String?
  isActive   Boolean  @default(true)
  businessId String
  business   Business @relation(fields: [businessId], references: [id])

  purchaseOrders PurchaseOrder[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("paynpik_vendors")
}

model PurchaseOrder {
  id            String   @id @default(cuid())
  poNumber      String   @unique
  quantity      Decimal  @db.Decimal(10, 3)
  unitPrice     Decimal  @db.Decimal(10, 2)
  totalAmount   Decimal  @db.Decimal(10, 2)
  status        String   @default("PENDING")
  paymentStatus String   @default("UNPAID")
  vendorId      String
  vendor        Vendor   @relation(fields: [vendorId], references: [id])
  materialId    String
  material      Material @relation(fields: [materialId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("paynpik_purchase_orders")
}

model ConsumptionLog {
  id         String   @id @default(cuid())
  quantity   Decimal  @db.Decimal(10, 3)
  purpose    String?
